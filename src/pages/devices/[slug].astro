---
import type {
  ProductDetailResponse,
  ProductSlugsResponse,
  ProductsIndexResponse,
} from "../../../data/exports/types";
import DeviceRelatedLink from "../../components/devices/DeviceRelatedLink.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import CompatibilityBadge from "../../components/ui/CompatibilityBadge.astro";
import DetailSidebarCard from "../../components/ui/DetailSidebarCard.astro";
import EntityDetailHero from "../../components/ui/EntityDetailHero.astro";
import EntityLinkList from "../../components/ui/EntityLinkList.astro";
import MetricCardGrid from "../../components/ui/MetricCardGrid.astro";
import ProtocolBadge from "../../components/ui/ProtocolBadge.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readExportJson } from "../../lib/exports";
import {
  formatBooleanFact,
  formatProtocolLabel,
  getProtocolStyle,
  sentenceCase,
} from "../../lib/ui";

export async function getStaticPaths() {
  const { slugs } = await readExportJson<ProductSlugsResponse>(
    "products/slugs.json",
  );

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing product slug.");
}

const detail = await readExportJson<ProductDetailResponse>(
  `products/${slug}.json`,
);
const allProducts =
  await readExportJson<ProductsIndexResponse>("products.json");

const product = detail.product;
const relatedProducts = allProducts.products
  .filter((candidate) => candidate.slug !== product.slug)
  .sort((left, right) => {
    const leftScore =
      Number(left.manufacturer?.slug === product.manufacturer?.slug) * 2 +
      Number(left.primaryProtocol === product.primaryProtocol) +
      Number(left.categoryPath.join("/") === product.categoryPath.join("/"));
    const rightScore =
      Number(right.manufacturer?.slug === product.manufacturer?.slug) * 2 +
      Number(right.primaryProtocol === product.primaryProtocol) +
      Number(right.categoryPath.join("/") === product.categoryPath.join("/"));

    if (leftScore !== rightScore) {
      return rightScore - leftScore;
    }

    return left.name.localeCompare(right.name);
  })
  .slice(0, 4);

const formatCount = new Intl.NumberFormat("en-US");
const protocolStyle = getProtocolStyle(product.primaryProtocol);
const updatedLabel = new Date(product.updatedAt).toLocaleDateString("en-US", {
  dateStyle: "medium",
});
const generatedLabel = new Date(detail.generated).toLocaleString("en-US", {
  dateStyle: "medium",
  timeStyle: "short",
});
const nearbyLinks = [
  {
    href: "/devices",
    label: "Browse all devices",
  },
  product.category
    ? {
        href: `/categories/${product.categoryPath.join("/")}`,
        label: `View ${product.category.name}`,
      }
    : null,
  product.primaryProtocol
    ? {
        href: `/protocols/${product.primaryProtocol}`,
        label: `Browse ${formatProtocolLabel(product.primaryProtocol)}`,
      }
    : null,
].filter((item): item is { href: string; label: string } => Boolean(item));
const summary =
  product.description && product.description !== product.name
    ? product.description
    : `${product.name} works with ${product.integrationCompatibility.length} integration${product.integrationCompatibility.length === 1 ? "" : "s"}, ${product.platformCompatibility.length} platform${product.platformCompatibility.length === 1 ? "" : "s"}, and ${product.hubCompatibility.length} commercial hub${product.hubCompatibility.length === 1 ? "" : "s"} in SmartPicker.`;
const compatibilityMetrics = [
  {
    value: formatCount.format(product.integrationCompatibility.length),
    label: "Direct integrations",
    description:
      "Direct software support through integrations such as Zigbee2MQTT, ZHA, or Z-Wave JS.",
  },
  {
    value: formatCount.format(product.platformCompatibility.length),
    label: "Derived platforms",
    description:
      "Platform support available through compatible integrations, with each route shown clearly.",
  },
  {
    value: formatCount.format(product.hubCompatibility.length),
    label: "Commercial hubs",
    description:
      "Support for dedicated hub ecosystems and commercial hub products.",
  },
];

const technicalDetails: Array<{ label: string; value: string }> = [
  { label: "Model", value: product.model ?? "Unknown" },
  {
    label: "Primary protocol",
    value: formatProtocolLabel(product.primaryProtocol),
  },
  {
    label: "Category",
    value: product.category?.name ?? "Uncategorized",
  },
  {
    label: "Catalog refreshed",
    value: generatedLabel,
  },
];

if (product.zigbeeDetails) {
  technicalDetails.push(
    {
      label: "IEEE manufacturer",
      value: product.zigbeeDetails.ieeeManufacturer ?? "Unknown",
    },
    {
      label: "Model ID",
      value: product.zigbeeDetails.modelId ?? "Unknown",
    },
    {
      label: "Endpoints",
      value:
        product.zigbeeDetails.endpoints == null
          ? "Not listed"
          : JSON.stringify(product.zigbeeDetails.endpoints),
    },
  );
}

if (product.zwaveDetails) {
  technicalDetails.push(
    {
      label: "Z-Wave manufacturer ID",
      value: product.zwaveDetails.zwaveManufacturerId ?? "Unknown",
    },
    {
      label: "Product type",
      value: product.zwaveDetails.productType ?? "Unknown",
    },
    {
      label: "Product ID",
      value: product.zwaveDetails.productIdHex ?? "Unknown",
    },
    {
      label: "Frequency",
      value: product.zwaveDetails.frequency ?? "Unknown",
    },
  );
}
---

<BaseLayout
  title={`${product.name} | SmartPicker`}
  description={`${product.name}${product.model ? ` (${product.model})` : ""} compatibility details across integrations, platforms, and commercial hubs.`}
>
  <div class="mx-auto max-w-[1200px] px-6">
    <Breadcrumbs
      items={[
        { href: "/", label: "Home" },
        { href: "/devices", label: "Devices" },
        { label: product.name },
      ]}
    />

    <div class="pb-10">
      <EntityDetailHero
        class="pb-6"
        layout="media-left"
        title={product.name}
        description={summary}
        stats={[
          {
            value: formatCount.format(product.integrationCompatibility.length),
            label: "Integrations",
          },
          {
            value: formatCount.format(product.platformCompatibility.length),
            label: "Platforms",
          },
          {
            value: formatCount.format(product.hubCompatibility.length),
            label: "Hubs",
          },
          { value: updatedLabel, label: "Updated", muted: true },
        ]}
      >
        <div
          slot="icon"
          class="border-theme bg-surface relative flex aspect-square items-center justify-center overflow-hidden rounded-2xl border text-[80px]"
        >
          <span
            class={`absolute top-3 left-3 rounded-full px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide ${protocolStyle.badge} ${protocolStyle.text}`}
          >
            {formatProtocolLabel(product.primaryProtocol)}
          </span>
          <span class="text-muted text-[72px] font-semibold tracking-[-0.08em]">
            {protocolStyle.shortLabel}
          </span>
        </div>

        <CompatibilityBadge
          slot="badges"
          status={product.compatibilityStatuses[0] ?? null}
          fallbackLabel="Reported"
          class="px-3 py-1 text-[13px] font-medium"
        />
        {
          product.primaryProtocol && (
            <a slot="badges" href={`/protocols/${product.primaryProtocol}`}>
              <ProtocolBadge
                slug={product.primaryProtocol}
                class="border-badge rounded-md border px-3 py-1 text-[13px] font-medium"
              />
            </a>
          )
        }
        {
          product.matterCertified && (
            <span
              slot="badges"
              class="border-green bg-green-subtle text-green rounded-md border px-3 py-1 text-[13px] font-medium"
            >
              Matter certified
            </span>
          )
        }
        {
          product.requiresHub === false && (
            <span
              slot="badges"
              class="border-green bg-green-subtle text-green rounded-md border px-3 py-1 text-[13px] font-medium"
            >
              No hub required
            </span>
          )
        }
        {
          product.localControl === true && (
            <span
              slot="badges"
              class="border-green bg-green-subtle text-green rounded-md border px-3 py-1 text-[13px] font-medium"
            >
              Local control
            </span>
          )
        }
      </EntityDetailHero>

      <div class="grid gap-3 md:grid-cols-4">
        <div class="border-theme bg-surface rounded-2xl border p-4">
          <div
            class="text-muted text-[11px] font-semibold tracking-wider uppercase"
          >
            Manufacturer
          </div>
          <div class="text-primary mt-1 text-sm font-semibold">
            {
              product.manufacturer ? (
                <a href={`/manufacturers/${product.manufacturer.slug}`}>
                  {product.manufacturer.name}
                </a>
              ) : (
                "Unknown manufacturer"
              )
            }
          </div>
        </div>
        <div class="border-theme bg-surface rounded-2xl border p-4">
          <div
            class="text-muted text-[11px] font-semibold tracking-wider uppercase"
          >
            Model
          </div>
          <div class="text-primary mt-1 text-sm font-semibold">
            {product.model ?? "Unknown"}
          </div>
        </div>
        <div class="border-theme bg-surface rounded-2xl border p-4">
          <div
            class="text-muted text-[11px] font-semibold tracking-wider uppercase"
          >
            Cloud required
          </div>
          <div class="text-primary mt-1 text-sm font-semibold">
            {formatBooleanFact(product.cloudDependent, "Yes", "No")}
          </div>
        </div>
        <div class="border-theme bg-surface rounded-2xl border p-4">
          <div
            class="text-muted text-[11px] font-semibold tracking-wider uppercase"
          >
            Requires hub
          </div>
          <div class="text-primary mt-1 text-sm font-semibold">
            {formatBooleanFact(product.requiresHub, "Yes", "No")}
          </div>
        </div>
      </div>
    </div>

    <section class="grid gap-6 pb-20 lg:grid-cols-[minmax(0,1.55fr)_320px]">
      <div class="flex flex-col gap-6">
        <section>
          <SectionHeader
            eyebrow="Compatibility Snapshot"
            title="How this device fits into a stack"
            description="See the main ways this device can fit into your setup, from direct integrations to broader platform and hub support."
          />
          <MetricCardGrid items={compatibilityMetrics} tone="accent" />
        </section>

        <section>
          <SectionHeader
            eyebrow="Direct Layer"
            title="Integration compatibility"
            description="These integrations are the clearest routes for using this device in a real setup."
          />
          <div class="grid gap-3">
            {
              product.integrationCompatibility.length > 0 ? (
                product.integrationCompatibility.map((entry) => (
                  <div class="border-theme bg-surface rounded-2xl border p-5">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                      <div>
                        <div class="text-primary text-base font-semibold">
                          <a href={`/integrations/${entry.integration.slug}`}>
                            {entry.integration.name}
                          </a>
                        </div>
                        <div class="text-muted mt-1 text-sm">
                          {entry.manufacturer?.name ?? "Independent"} ·{" "}
                          {entry.platformSlugs.length > 0
                            ? `${entry.platformSlugs.length} linked platform${entry.platformSlugs.length === 1 ? "" : "s"}`
                            : "No linked platforms listed"}
                        </div>
                      </div>
                      <CompatibilityBadge
                        status={entry.status}
                        fallbackLabel="Reported"
                        class="px-3 py-1 text-[13px] font-medium"
                      />
                    </div>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {entry.platformSlugs.map((platformSlug) => (
                        <a
                          href={`/platforms/${platformSlug}`}
                          class="border-theme bg-badge text-secondary hover:border-theme-hover hover:text-primary rounded-md border px-3 py-1 text-[12px] font-medium transition-all"
                        >
                          {sentenceCase(platformSlug.replace(/-/g, " "))}
                        </a>
                      ))}
                    </div>
                    {(entry.supportSummary || entry.lastConfirmedAt) && (
                      <p class="text-secondary mt-3 text-sm leading-relaxed">
                        {entry.supportSummary ?? "No support summary provided."}
                        {entry.lastConfirmedAt &&
                          ` Last confirmed ${new Date(entry.lastConfirmedAt).toLocaleDateString("en-US", { dateStyle: "medium" })}.`}
                      </p>
                    )}
                  </div>
                ))
              ) : (
                <div class="border-theme bg-surface text-muted rounded-2xl border px-5 py-6 text-sm">
                  No direct integration compatibility rows are currently listed
                  for this device.
                </div>
              )
            }
          </div>
        </section>

        <section>
          <SectionHeader
            eyebrow="Derived Layer"
            title="Platform compatibility"
            description="Whenever a platform is shown, SmartPicker also shows which integrations make that compatibility true."
          />
          <div class="grid gap-3">
            {
              product.platformCompatibility.length > 0 ? (
                product.platformCompatibility.map((entry) => (
                  <div class="border-theme bg-surface rounded-2xl border p-5">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                      <div>
                        <div class="text-primary text-base font-semibold">
                          <a href={`/platforms/${entry.platform.slug}`}>
                            {entry.platform.name}
                          </a>
                        </div>
                        <div class="text-muted mt-1 text-sm">
                          {sentenceCase(entry.kind.replace(/_/g, " "))}
                        </div>
                      </div>
                      <CompatibilityBadge
                        status={entry.status}
                        fallbackLabel="Reported"
                        class="px-3 py-1 text-[13px] font-medium"
                      />
                    </div>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {entry.viaIntegrations.map((integration) => (
                        <a
                          href={`/integrations/${integration.slug}`}
                          class="border-blue bg-blue-subtle text-blue rounded-md border px-3 py-1 text-[12px] font-medium"
                        >
                          Via {integration.name}
                        </a>
                      ))}
                    </div>
                  </div>
                ))
              ) : (
                <div class="border-theme bg-surface text-muted rounded-2xl border px-5 py-6 text-sm">
                  Platform support is not listed for this device.
                </div>
              )
            }
          </div>
        </section>

        <section>
          <SectionHeader
            eyebrow="Commercial Layer"
            title="Hub compatibility"
            description="Commercial hub compatibility is tracked separately from open platforms and integrations."
          />
          <div class="grid gap-3">
            {
              product.hubCompatibility.length > 0 ? (
                product.hubCompatibility.map((entry) => (
                  <div class="border-theme bg-surface rounded-2xl border p-5">
                    <div class="flex flex-wrap items-start justify-between gap-3">
                      <div>
                        <div class="text-primary text-base font-semibold">
                          <a href={`/hubs/${entry.hub.slug}`}>
                            {entry.hub.name}
                          </a>
                        </div>
                        <div class="text-muted mt-1 text-sm">
                          {entry.manufacturer?.name ?? "Independent"}
                        </div>
                      </div>
                      <CompatibilityBadge
                        status={entry.status}
                        fallbackLabel="Reported"
                        class="px-3 py-1 text-[13px] font-medium"
                      />
                    </div>
                    {(entry.supportSummary || entry.lastConfirmedAt) && (
                      <p class="text-secondary mt-3 text-sm leading-relaxed">
                        {entry.supportSummary ?? "No support summary provided."}
                        {entry.lastConfirmedAt &&
                          ` Last confirmed ${new Date(entry.lastConfirmedAt).toLocaleDateString("en-US", { dateStyle: "medium" })}.`}
                      </p>
                    )}
                  </div>
                ))
              ) : (
                <div class="border-theme bg-surface text-muted rounded-2xl border px-5 py-6 text-sm">
                  No direct commercial hub compatibility rows are currently
                  listed for this device.
                </div>
              )
            }
          </div>
        </section>

        <section>
          <SectionHeader
            eyebrow="Technical"
            title="Technical details"
            description="Protocol, hardware, and identifying details that help you compare versions and plan setup."
          />
          <div
            class="border-theme grid gap-px overflow-hidden rounded-2xl border bg-[var(--sp-border)]"
          >
            {
              technicalDetails.map((row) => (
                <div class="bg-surface grid grid-cols-[220px_1fr] gap-4 px-5 py-4 max-md:grid-cols-1">
                  <div class="text-primary text-sm font-semibold">
                    {row.label}
                  </div>
                  <div class="text-secondary text-sm">{row.value}</div>
                </div>
              ))
            }
          </div>
        </section>

        <section>
          <SectionHeader
            eyebrow="Setup"
            title="Infrastructure hints"
            description="Optional coordinator, adapter, or hardware hints that help explain setup requirements."
          />
          <div class="grid gap-3 md:grid-cols-2">
            {
              product.infrastructureHints.length > 0 ? (
                product.infrastructureHints.map((hint) => (
                  <div class="border-theme bg-surface rounded-2xl border p-5">
                    <div class="text-primary text-base font-semibold">
                      <a href={`/devices/${hint.product.slug}`}>
                        {hint.product.name}
                      </a>
                    </div>
                    <div class="text-muted mt-1 text-sm">
                      {hint.manufacturer?.name ?? "Unknown manufacturer"} ·{" "}
                      {hint.category?.name ?? "Uncategorized"}
                    </div>
                    <div class="border-theme bg-badge text-secondary mt-3 inline-flex rounded-full border px-3 py-1 text-[12px] font-medium">
                      {sentenceCase(hint.requirementType.replace(/_/g, " "))}
                    </div>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {hint.viaIntegrations.map((integration) => (
                        <a
                          href={`/integrations/${integration.slug}`}
                          class="border-blue bg-blue-subtle text-blue rounded-md border px-3 py-1 text-[12px] font-medium"
                        >
                          Via {integration.name}
                        </a>
                      ))}
                    </div>
                    {hint.note && (
                      <p class="text-secondary mt-3 text-sm leading-relaxed">
                        {hint.note}
                      </p>
                    )}
                  </div>
                ))
              ) : (
                <div class="border-theme bg-surface text-muted rounded-2xl border px-5 py-6 text-sm md:col-span-2">
                  No infrastructure hints are currently attached to this device.
                </div>
              )
            }
          </div>
        </section>

        <section>
          <SectionHeader
            eyebrow="Related"
            title="Similar devices"
            description="Nearby matches by manufacturer, protocol, and category."
          />
          <div
            class="border-theme bg-surface overflow-hidden rounded-2xl border"
          >
            {
              relatedProducts.length > 0 ? (
                relatedProducts.map((candidate) => (
                  <DeviceRelatedLink
                    href={`/devices/${candidate.slug}`}
                    name={candidate.name}
                    manufacturerName={
                      candidate.manufacturer?.name ?? "Unknown manufacturer"
                    }
                    model={candidate.model}
                    protocolSlug={candidate.primaryProtocol}
                  />
                ))
              ) : (
                <div class="text-muted px-5 py-6 text-sm">
                  No related devices are listed right now.
                </div>
              )
            }
          </div>
        </section>
      </div>

      <aside class="flex flex-col gap-6">
        <DetailSidebarCard
          title="Quick facts"
          rows={[
            {
              label: "Manufacturer",
              value: product.manufacturer?.name ?? "Unknown",
            },
            {
              label: "Category",
              value: product.category?.name ?? "Uncategorized",
            },
            {
              label: "Updated",
              value: updatedLabel,
            },
            {
              label: "Catalog refreshed",
              value: generatedLabel,
            },
          ]}
        />

        <EntityLinkList
          title="Browse nearby"
          items={nearbyLinks}
          emptyText="No nearby browse links are available right now."
        />
      </aside>
    </section>
  </div>
</BaseLayout>
