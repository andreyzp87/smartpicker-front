---
import DeviceCatalogBrowser from "../../components/devices/DeviceCatalogBrowser";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageIntro from "../../components/ui/PageIntro.astro";
import { createDefaultCatalogState, getCatalogResults } from "../../lib/catalog/core";
import { readExportJson } from "../../lib/exports";
import { getCatalogPayload } from "../../lib/catalog/server";

interface ProductSummary {
  localControl: boolean | null;
  cloudDependent: boolean | null;
  requiresHub: boolean | null;
  matterCertified: boolean | null;
}

interface ProductsExport {
  count: number;
  products: ProductSummary[];
}

const products = await readExportJson<ProductsExport>("products.json");
const catalogPayload = await getCatalogPayload();

const featureCounts = {
  localControl: products.products.filter((product) => product.localControl === true)
    .length,
  matterCertified: products.products.filter(
    (product) => product.matterCertified === true,
  ).length,
  noCloud: products.products.filter((product) => product.cloudDependent === false)
    .length,
  noHub: products.products.filter((product) => product.requiresHub === false).length,
};
const initialCatalog = getCatalogResults(
  catalogPayload,
  createDefaultCatalogState(),
  "",
  undefined,
  12,
);

const formatCount = new Intl.NumberFormat("en-US");
---

<BaseLayout
  title="Browse Devices | SmartPicker"
  description="Browse smart home devices by protocol, manufacturer, and key features with SmartPicker."
>
  <div class="mx-auto max-w-[1200px] px-6">
    <PageIntro
      title="Browse Devices"
      description="Find compatible smart home devices for your setup. Use filters to narrow the catalog by protocol, manufacturer, and features such as local control, Matter certification, and hub requirements."
      stats={[
        { value: formatCount.format(products.count), label: "Devices" },
        { value: formatCount.format(catalogPayload.facets.protocols.length), label: "Protocols" },
        { value: formatCount.format(catalogPayload.facets.manufacturers.length), label: "Manufacturers" },
      ]}
    />

    <DeviceCatalogBrowser
      client:load
      initialCatalog={{
        products: initialCatalog.pagedProducts,
        totalCount: initialCatalog.filteredProducts.length,
        totalPages: initialCatalog.totalPages,
        page: initialCatalog.safePage,
        from: initialCatalog.from,
        to: initialCatalog.to,
      }}
      initialFacets={{
        protocols: catalogPayload.facets.protocols,
        manufacturers: catalogPayload.facets.manufacturers,
        categories: catalogPayload.facets.categories,
        integrations: catalogPayload.facets.integrations,
        platforms: catalogPayload.facets.platforms,
        hubs: catalogPayload.facets.hubs,
        featureCounts,
      }}
      endpoints={{ catalog: "/catalog.json", autoloadMode: "scroll" }}
      uiConfig={{ pageSize: 12 }}
    />
  </div>
</BaseLayout>
