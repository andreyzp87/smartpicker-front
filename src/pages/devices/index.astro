---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readExportJson } from "../../lib/exports";

interface ProductsExport {
  count: number;
}

const products = await readExportJson<ProductsExport>("products.json");
---

<BaseLayout
  title="Devices | SmartPicker"
  description="Temporary devices landing page for the Astro foundation pass."
>
  <section class="panel mx-auto max-w-3xl p-8">
    <p
      class="text-brand-strong text-sm font-semibold tracking-[0.24em] uppercase"
    >
      Devices
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight">
      Catalog route placeholder
    </h1>
    <p class="text-muted mt-4 text-base leading-8">
      The full device catalog is still ahead of us, but this route is live and
      reading the local export data successfully. Current imported devices: <span
        class="text-foreground font-semibold">{products.count}</span
      >.
    </p>
  </section>
</BaseLayout>
