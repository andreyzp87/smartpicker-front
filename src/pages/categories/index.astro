---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategorySummaryCard from "../../components/categories/CategorySummaryCard.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import PageIntro from "../../components/ui/PageIntro.astro";
import { readExportJson } from "../../lib/exports";

interface CategorySummary {
  slug: string;
  name: string;
  path: string;
  pathSegments: string[];
  children: { id: number; slug: string; name: string }[];
  directDeviceCount: number;
  deviceCount: number;
}

interface CategoriesExport {
  count: number;
  categories: CategorySummary[];
}

interface ProductsExport {
  count: number;
}

const categories = await readExportJson<CategoriesExport>("categories.json");
const products = await readExportJson<ProductsExport>("products.json");

const rootCategories = categories.categories.filter(
  (category) => category.pathSegments.length <= 1,
);
const subcategoryCount = categories.categories.filter(
  (category) => category.pathSegments.length > 1,
).length;
const formatCount = new Intl.NumberFormat("en-US");
---

<BaseLayout
  title="Categories | SmartPicker"
  description="Browse device categories in SmartPicker and explore products by function."
>
  <div class="mx-auto max-w-[1200px] px-6">
    <PageIntro
      title="Device Categories"
      description={`Explore devices organized by function and room, then drill into subcategories and related products.`}
      stats={[
        { value: formatCount.format(rootCategories.length), label: "Categories" },
        { value: formatCount.format(subcategoryCount), label: "Subcategories" },
        { value: formatCount.format(products.count), label: "Total devices" },
      ]}
    />

    {
      categories.count > 0 ? (
        <section class="grid gap-4 pb-20 [grid-template-columns:repeat(auto-fit,minmax(280px,1fr))]">
          {rootCategories.map((category, index) => (
            <div style={`animation-delay:${0.05 + index * 0.05}s`}>
              <CategorySummaryCard
                href={`/categories/${category.path}`}
                name={category.name}
                deviceCount={formatCount.format(category.deviceCount)}
                description={
                  category.children.length > 0
                    ? `${category.children.length} subcategorie${category.children.length === 1 ? "y" : "s"} available under this section.`
                    : "Browse devices directly from this top-level category."
                }
                directCount={formatCount.format(category.directDeviceCount)}
                nestedCount={formatCount.format(
                  category.deviceCount - category.directDeviceCount,
                )}
              />
            </div>
          ))}
        </section>
      ) : (
        <section class="pb-20">
          <EmptyState
            icon="#"
            title="Categories are being expanded"
            description="Category coverage is still limited, so browsing is currently strongest by device, manufacturer, and protocol. You can still explore the full catalog from the links below."
            primaryAction={{ href: "/devices", label: "Browse all devices" }}
            secondaryAction={{
              href: "/manufacturers",
              label: "Explore manufacturers",
            }}
          >
            <div class="mt-4 grid gap-4 [grid-template-columns:repeat(auto-fit,minmax(280px,1fr))]">
              <article class="rounded-2xl border border-theme bg-elevated p-5">
                <h3 class="mb-3 text-lg font-bold tracking-tight">
                  Best ways to browse now
                </h3>
                <p class="text-sm leading-relaxed text-secondary">
                  Start with the full device catalog, compare brands, or narrow
                  your search by protocol to find products that fit your setup.
                </p>
              </article>
              <article class="rounded-2xl border border-theme bg-elevated p-5">
                <h3 class="mb-3 text-lg font-bold tracking-tight">
                  What category pages will add
                </h3>
                <p class="text-sm leading-relaxed text-secondary">
                  As category coverage grows, these pages will make it easier to
                  move from broad product types to the devices that fit a
                  specific room or use case.
                </p>
              </article>
            </div>
          </EmptyState>
        </section>
      )
    }
  </div>
</BaseLayout>
