---
import CatalogSection from "../../components/devices/CatalogSection.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import ButtonLink from "../../components/ui/ButtonLink.astro";
import DetailSidebarCard from "../../components/ui/DetailSidebarCard.astro";
import EntityDetailHero from "../../components/ui/EntityDetailHero.astro";
import EntityLinkList from "../../components/ui/EntityLinkList.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import {
  createDefaultCatalogState,
  getCatalogResults,
} from "../../lib/catalog/core";
import { getCatalogPayload } from "../../lib/catalog/server";
import { readExportJson } from "../../lib/exports";
import { formatProtocolLabel } from "../../lib/ui";

interface EntityRef {
  id: number;
  slug: string;
  name: string;
}

interface CategoryPathEntry {
  slug: string;
  path: string;
  pathSegments: string[];
}

interface CategoryPathsExport {
  categories: CategoryPathEntry[];
}

interface CategoryDetail {
  slug: string;
  name: string;
  path: string;
  pathSegments: string[];
  ancestors: EntityRef[];
  children: EntityRef[];
  directDeviceCount: number;
  deviceCount: number;
  updatedAt: string | null;
  directDeviceSlugs: string[];
  deviceSlugs: string[];
}

interface CategoryDetailResponse {
  generated: string;
  category: CategoryDetail;
}

interface ProductSummary {
  slug: string;
  name: string;
  manufacturer: EntityRef | null;
  model: string | null;
  primaryProtocol: string | null;
  compatibleHubSlugs: string[];
}

interface ProductsExport {
  products: ProductSummary[];
}

export async function getStaticPaths() {
  const paths = await readExportJson<CategoryPathsExport>(
    "categories/paths.json",
  );

  return paths.categories.map((category) => ({
    params: {
      slug: category.path,
    },
  }));
}

const slugSegments = Array.isArray(Astro.params.slug)
  ? Astro.params.slug.filter(Boolean)
  : typeof Astro.params.slug === "string"
    ? Astro.params.slug.split("/").filter(Boolean)
    : [];

if (slugSegments.length === 0) {
  throw new Error("Missing category slug.");
}

const categoryPath = slugSegments.join("/");
const detail = await readExportJson<CategoryDetailResponse>(
  `categories/${categoryPath}.json`,
);
const products = await readExportJson<ProductsExport>("products.json");
const catalogPayload = await getCatalogPayload();

const category = detail.category;
const mappedProducts = products.products.filter((product) =>
  category.deviceSlugs.includes(product.slug),
);
const formatCount = new Intl.NumberFormat("en-US");
const breadcrumbItems = [
  { href: "/", label: "Home" },
  { href: "/categories", label: "Categories" },
  ...category.ancestors.map((ancestor, index) => ({
    href: `/categories/${category.pathSegments.slice(0, index + 1).join("/")}`,
    label: ancestor.name,
  })),
  { label: category.name },
];
const updatedLabel = category.updatedAt
  ? new Date(category.updatedAt).toLocaleDateString("en-US", {
      dateStyle: "medium",
    })
  : "Unknown";
const exportGenerated = new Date(detail.generated).toLocaleDateString("en-US", {
  dateStyle: "medium",
});
const summaryText =
  category.children.length > 0
    ? `${category.name} includes ${category.children.length} subcategorie${category.children.length === 1 ? "y" : "s"} and ${category.deviceCount} device${category.deviceCount === 1 ? "" : "s"} in total.`
    : `${category.name} includes ${category.deviceCount} device${category.deviceCount === 1 ? "" : "s"} in this category.`;
const featureCounts = Object.fromEntries(
  catalogPayload.facets.features.map((feature) => [feature.key, feature.count]),
) as {
  localControl: number;
  matterCertified: number;
  noCloud: number;
  noHub: number;
};
const initialCatalog = getCatalogResults(
  catalogPayload,
  createDefaultCatalogState(),
  "",
  { categories: [category.path] },
  12,
);
const subcategoryItems = category.children.map((child) => ({
  href: `/categories/${[...category.pathSegments, child.slug].join("/")}`,
  label: child.name,
  icon: "#",
  meta: child.slug,
}));
const categoryDeviceItems = mappedProducts.map((product) => ({
  href: `/devices/${product.slug}`,
  label: product.name,
  icon: product.model?.slice(0, 2).toUpperCase() ?? "SP",
  meta: `${product.manufacturer?.name ?? "Unknown manufacturer"} · ${product.model ?? "Model TBD"}${product.primaryProtocol ? ` · ${formatProtocolLabel(product.primaryProtocol)}` : ""}`,
}));
---

<BaseLayout
  title={`${category.name} | SmartPicker`}
  description={`${category.name} category page in SmartPicker.`}
>
  <div class="mx-auto max-w-[1200px] px-6">
    <Breadcrumbs items={breadcrumbItems} />

    <EntityDetailHero
      class="animate-fade-in"
      icon="#"
      title={category.name}
      description={`${summaryText} Use this page to move from broad product types to the devices that fit a specific room, task, or use case.`}
      statsWrapperClass="max-w-[760px]"
      statsColumnsClass="grid-cols-3 max-md:grid-cols-1"
      stats={[
        {
          value: formatCount.format(category.deviceCount),
          label: "Total devices",
        },
        {
          value: formatCount.format(category.directDeviceCount),
          label: "Direct devices",
        },
        {
          value: formatCount.format(category.children.length),
          label: "Children",
        },
      ]}
    />

    <div class="grid gap-6 pb-20 lg:grid-cols-[minmax(0,1fr)_320px]">
      <div class="flex flex-col gap-6">
        <section class="animate-fade-in">
          <SectionHeader
            eyebrow="Hierarchy"
            title="Subcategories"
            description="Use subcategories to narrow your search when you want a more specific product type."
          />
          <EntityLinkList
            items={subcategoryItems}
            emptyText="No subcategories are currently listed beneath this category."
            variant="content"
          />
        </section>

        <section class="animate-fade-in">
          <SectionHeader
            eyebrow="Membership"
            title="Devices in this category"
            description="Browse the devices currently listed in this category and jump directly into their compatibility details."
          />
          <EntityLinkList
            items={categoryDeviceItems}
            emptyText="No devices are currently listed in this category."
            variant="content"
          />
        </section>
      </div>

      <aside class="flex flex-col gap-6 max-lg:order-first">
        <div class="animate-fade-in" style="animation-delay:0.1s">
          <DetailSidebarCard
            title="Category Info"
            rows={[
              {
                label: "Path",
                value: category.path,
                mono: true,
              },
              {
                label: "Updated",
                value: updatedLabel,
              },
              {
                label: "Catalog refreshed",
                value: exportGenerated,
              },
            ]}
          />
        </div>

        <ButtonLink href="/devices" variant="secondary" class="justify-center">
          Browse all devices →
        </ButtonLink>
      </aside>
    </div>

    <CatalogSection
      title={`Browse ${category.name} devices`}
      description="Browse devices in this category and refine the list by protocol, manufacturer, or key features."
      initialCatalog={{
        products: initialCatalog.pagedProducts,
        totalCount: initialCatalog.filteredProducts.length,
        totalPages: initialCatalog.totalPages,
        page: initialCatalog.safePage,
        from: initialCatalog.from,
        to: initialCatalog.to,
      }}
      initialFacets={{
        protocols: catalogPayload.facets.protocols,
        manufacturers: catalogPayload.facets.manufacturers,
        categories: catalogPayload.facets.categories,
        integrations: catalogPayload.facets.integrations,
        platforms: catalogPayload.facets.platforms,
        hubs: catalogPayload.facets.hubs,
        featureCounts,
      }}
      uiConfig={{
        hiddenSections: { categories: true },
        lockedFilters: { categories: [category.path] },
      }}
    />
  </div>
</BaseLayout>
