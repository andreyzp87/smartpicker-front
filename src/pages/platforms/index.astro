---
import type { PlatformsResponse } from "../../../data/exports/types";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PlatformTableCell from "../../components/platforms/PlatformTableCell.astro";
import DataTableSection from "../../components/ui/DataTableSection.astro";
import PageIntro from "../../components/ui/PageIntro.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import { readExportJson } from "../../lib/exports";
import { sentenceCase } from "../../lib/ui";

const platforms = await readExportJson<PlatformsResponse>("platforms.json");
const sortedPlatforms = [...platforms.platforms].sort((left, right) =>
  right.compatibleDeviceCountDerived === left.compatibleDeviceCountDerived
    ? left.name.localeCompare(right.name)
    : right.compatibleDeviceCountDerived - left.compatibleDeviceCountDerived,
);
const formatCount = new Intl.NumberFormat("en-US");
const platformColumns = [
  { key: "platform", label: "Platform", width: "1.4fr" },
  { key: "kind", label: "Kind", width: "180px" },
  { key: "integrations", label: "Integrations", width: "160px" },
  {
    key: "coverage",
    label: "Coverage",
    width: "140px",
    align: "right" as const,
  },
];
---

<BaseLayout
  title="Platforms | SmartPicker"
  description="Browse smart home platforms and compare their integrations and device support."
>
  <div class="mx-auto max-w-[1200px] px-6">
    <PageIntro
      title="Platforms"
      description="Compare the apps and ecosystems people build around, then see which integrations and devices each platform supports."
      stats={[
        { value: formatCount.format(platforms.count), label: "Platforms" },
        {
          value: formatCount.format(
            sortedPlatforms.reduce(
              (sum, platform) => sum + platform.integrationSlugs.length,
              0,
            ),
          ),
          label: "Linked integrations",
        },
        {
          value: formatCount.format(
            sortedPlatforms.filter(
              (platform) => platform.compatibleDeviceCountDerived > 0,
            ).length,
          ),
          label: "With coverage",
        },
      ]}
    />

    <section class="mt-10">
      <SectionHeader
        title="Featured Platforms"
        description="Platforms with the broadest device support across their linked integrations."
      />
      <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        {
          sortedPlatforms.slice(0, 6).map((platform) => (
            <a
              href={`/platforms/${platform.slug}`}
              class="card-hover border-theme bg-surface text-primary rounded-2xl border p-5"
            >
              <div class="bg-elevated text-muted mb-3 flex h-11 w-11 items-center justify-center rounded-[10px] text-sm font-semibold">
                PF
              </div>
              <div class="text-base font-semibold">{platform.name}</div>
              <div class="text-muted mt-1 text-[13px]">
                {sentenceCase(platform.kind.replace(/_/g, " "))}
              </div>
              <div class="text-muted mt-4 flex flex-wrap gap-2 text-[11px]">
                <span class="border-theme bg-badge rounded-md border px-2 py-1">
                  {platform.integrationSlugs.length} integration
                  {platform.integrationSlugs.length === 1 ? "" : "s"}
                </span>
                <span class="border-theme bg-badge rounded-md border px-2 py-1">
                  {formatCount.format(platform.compatibleDeviceCountDerived)}{" "}
                  devices
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-14 pb-20">
      <DataTableSection
        title="All Platforms"
        subtitle="Compare platform type, integration reach, and overall device support."
        summaryLabel={`${formatCount.format(platforms.count)} platforms tracked`}
        columns={platformColumns}
        rows={sortedPlatforms}
        cellComponent={PlatformTableCell}
        getRowHref={(row) =>
          `/platforms/${(row as PlatformsResponse["platforms"][number]).slug}`}
      />
    </section>
  </div>
</BaseLayout>
