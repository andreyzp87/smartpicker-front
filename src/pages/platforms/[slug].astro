---
import type {
  PlatformDetailResponse,
  PlatformSlugsResponse,
  ProductsIndexResponse,
} from "../../../data/exports/types";
import CatalogSection from "../../components/devices/CatalogSection.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import DetailSidebarCard from "../../components/ui/DetailSidebarCard.astro";
import EntityCardGridSection from "../../components/ui/EntityCardGridSection.astro";
import EntityDetailHero from "../../components/ui/EntityDetailHero.astro";
import EntityLinkList from "../../components/ui/EntityLinkList.astro";
import MetricCardGrid from "../../components/ui/MetricCardGrid.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import {
  createDefaultCatalogState,
  getCatalogResults,
} from "../../lib/catalog/core";
import { getCatalogPayload } from "../../lib/catalog/server";
import { readExportJson } from "../../lib/exports";
import { sentenceCase } from "../../lib/ui";

export async function getStaticPaths() {
  const { slugs } = await readExportJson<PlatformSlugsResponse>(
    "platforms/slugs.json",
  );

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing platform slug.");
}

const detail = await readExportJson<PlatformDetailResponse>(
  `platforms/${slug}.json`,
);
const products = await readExportJson<ProductsIndexResponse>("products.json");
const catalogPayload = await getCatalogPayload();

const platform = detail.platform;
const productBySlug = new Map(
  products.products.map((product) => [product.slug, product]),
);
const compatibleProducts = platform.compatibleDeviceSlugs
  .map((deviceSlug) => productBySlug.get(deviceSlug))
  .filter((product): product is ProductsIndexResponse["products"][number] =>
    Boolean(product),
  )
  .slice(0, 8);
const featureCounts = Object.fromEntries(
  catalogPayload.facets.features.map((feature) => [feature.key, feature.count]),
) as {
  localControl: number;
  matterCertified: number;
  noCloud: number;
  noHub: number;
};
const initialCatalog = getCatalogResults(
  catalogPayload,
  createDefaultCatalogState(),
  "",
  { platforms: [platform.slug] },
  12,
);
const formatCount = new Intl.NumberFormat("en-US");
const updatedLabel = new Date(platform.updatedAt).toLocaleDateString("en-US", {
  dateStyle: "medium",
});
const statusMetrics = Object.entries(platform.statusBreakdown).map(
  ([status, count]) => ({
    value: formatCount.format(count),
    label: sentenceCase(status),
  }),
);
const linkedIntegrationCards = platform.integrations.map((integration) => ({
  href: `/integrations/${integration.slug}`,
  title: integration.name,
  meta: integration.slug,
}));
const sampleDeviceItems = compatibleProducts.map((product) => ({
  href: `/devices/${product.slug}`,
  label: product.name,
}));
---

<BaseLayout
  title={`${platform.name} | SmartPicker`}
  description={`${platform.name} device support, linked integrations, and compatibility details in SmartPicker.`}
>
  <div class="mx-auto max-w-[1200px] px-6">
    <Breadcrumbs
      items={[
        { href: "/", label: "Home" },
        { href: "/platforms", label: "Platforms" },
        { label: platform.name },
      ]}
    />

    <EntityDetailHero
      icon="PF"
      title={platform.name}
      description={platform.description ?? platform.searchText}
      badges={[
        { label: sentenceCase(platform.kind.replace(/_/g, " ")) },
        { label: `Updated ${updatedLabel}` },
      ]}
      stats={[
        {
          value: formatCount.format(platform.compatibleDeviceCountDerived),
          label: "Supported devices",
        },
        {
          value: formatCount.format(platform.integrations.length),
          label: "Integrations",
        },
        {
          value: formatCount.format(
            Object.values(platform.statusBreakdown).reduce(
              (sum, value) => sum + value,
              0,
            ),
          ),
          label: "Status rows",
        },
        { value: updatedLabel, label: "Updated", muted: true },
      ]}
    />

    <div class="grid gap-6 pb-20 lg:grid-cols-[minmax(0,1.55fr)_320px]">
      <div class="flex flex-col gap-6">
        <EntityCardGridSection
          eyebrow="Integrations"
          title="Linked integrations"
          description="These integrations are the main ways devices connect to this platform."
          items={linkedIntegrationCards}
          emptyText="No integrations are listed for this platform yet."
        />

        <section>
          <SectionHeader
            eyebrow="Coverage"
            title="Status breakdown"
            description="Compatibility status across the devices that work with this platform."
          />
          <MetricCardGrid
            items={statusMetrics}
            tone="accent"
            emptyMessage="No status breakdown is available for this platform yet."
          />
        </section>

        <section>
          <SectionHeader
            eyebrow="Explanation"
            title="Why this platform is listed"
            description="Platforms appear when supported integrations bring devices into a broader ecosystem."
          />
          <div
            class="border-theme bg-surface text-secondary rounded-2xl border p-5 text-sm leading-relaxed"
          >
            {
              platform.integrations.length > 0
                ? `${platform.name} appears on SmartPicker because support is available through ${platform.integrations.map((integration) => integration.name).join(", ")}. Browse those integrations to see the exact path into the platform.`
                : `${platform.name} is listed here, but linked integrations have not been added yet.`
            }
          </div>
        </section>
      </div>

      <aside class="flex flex-col gap-6">
        <DetailSidebarCard
          title="At a glance"
          rows={[
            {
              label: "Kind",
              value: sentenceCase(platform.kind.replace(/_/g, " ")),
            },
            {
              label: "Manufacturer",
              value: platform.manufacturer?.name ?? "Independent",
            },
            {
              label: "Website",
              value: platform.website
                ? platform.website.replace(/^https?:[/]+/, "")
                : "Not listed",
              href: platform.website,
              external: Boolean(platform.website),
            },
          ]}
        />

        <EntityLinkList
          title="Sample devices"
          items={sampleDeviceItems}
          emptyText="No sample devices are available yet."
        />
      </aside>
    </div>

    <CatalogSection
      title={`Browse devices for ${platform.name}`}
      description="Browse devices that work with this platform and refine by protocol, manufacturer, integration, hub, and key features."
      initialCatalog={{
        products: initialCatalog.pagedProducts,
        totalCount: initialCatalog.filteredProducts.length,
        totalPages: initialCatalog.totalPages,
        page: initialCatalog.safePage,
        from: initialCatalog.from,
        to: initialCatalog.to,
      }}
      initialFacets={{
        protocols: catalogPayload.facets.protocols,
        manufacturers: catalogPayload.facets.manufacturers,
        categories: catalogPayload.facets.categories,
        integrations: catalogPayload.facets.integrations,
        platforms: catalogPayload.facets.platforms,
        hubs: catalogPayload.facets.hubs,
        featureCounts,
      }}
      uiConfig={{
        hiddenSections: { platforms: true },
        lockedFilters: { platforms: [platform.slug] },
      }}
    />
  </div>
</BaseLayout>
