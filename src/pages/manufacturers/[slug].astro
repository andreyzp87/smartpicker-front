---
import CatalogSection from "../../components/devices/CatalogSection.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ManufacturerCategoryTableCell from "../../components/manufacturers/ManufacturerCategoryTableCell.astro";
import ManufacturerProtocolCard from "../../components/manufacturers/ManufacturerProtocolCard.astro";
import ButtonLink from "../../components/ui/ButtonLink.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import DataTableSection from "../../components/ui/DataTableSection.astro";
import DetailSidebarCard from "../../components/ui/DetailSidebarCard.astro";
import EntityDetailHero from "../../components/ui/EntityDetailHero.astro";
import EntityLinkList from "../../components/ui/EntityLinkList.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import SidebarPanel from "../../components/ui/SidebarPanel.astro";
import {
  createDefaultCatalogState,
  getCatalogResults,
} from "../../lib/catalog/core";
import { getCatalogPayload } from "../../lib/catalog/server";
import { readExportJson } from "../../lib/exports";
import { formatProtocolLabel, getProtocolStyle } from "../../lib/ui";

interface EntityRef {
  id: number;
  slug: string;
  name: string;
}

interface ManufacturerDetail {
  id: number;
  slug: string;
  name: string;
  website: string | null;
  logoUrl: string | null;
  deviceCount: number;
  updatedAt: string | null;
  deviceSlugs: string[];
}

interface ManufacturerDetailResponse {
  generated: string;
  manufacturer: ManufacturerDetail;
}

interface ManufacturerSlugsResponse {
  slugs: string[];
}

interface ProductSummary {
  slug: string;
  name: string;
  manufacturer: EntityRef | null;
  model: string | null;
  category: EntityRef | null;
  primaryProtocol: string | null;
  compatibleHubSlugs: string[];
  compatibilityStatuses: string[];
  updatedAt: string;
}

interface ProductsExport {
  products: ProductSummary[];
}

interface HubSummary {
  slug: string;
  name: string;
  manufacturer: EntityRef | null;
}

interface HubsExport {
  hubs: HubSummary[];
}

interface ManufacturersExport {
  manufacturers: ManufacturerDetail[];
}

export async function getStaticPaths() {
  const { slugs } = await readExportJson<ManufacturerSlugsResponse>(
    "manufacturers/slugs.json",
  );

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing manufacturer slug.");
}

const detail = await readExportJson<ManufacturerDetailResponse>(
  `manufacturers/${slug}.json`,
);
const products = await readExportJson<ProductsExport>("products.json");
const hubs = await readExportJson<HubsExport>("hubs.json");
const manufacturers =
  await readExportJson<ManufacturersExport>("manufacturers.json");
const catalogPayload = await getCatalogPayload();

const manufacturer = detail.manufacturer;
const mappedProducts = products.products
  .filter((product) => manufacturer.deviceSlugs.includes(product.slug))
  .sort((left, right) => {
    const leftScore =
      left.compatibleHubSlugs.length * 10 + left.compatibilityStatuses.length;
    const rightScore =
      right.compatibleHubSlugs.length * 10 + right.compatibilityStatuses.length;

    if (leftScore !== rightScore) {
      return rightScore - leftScore;
    }

    return left.name.localeCompare(right.name);
  });

const protocolCounts = mappedProducts.reduce<Record<string, number>>(
  (counts, product) => {
    if (product.primaryProtocol) {
      counts[product.primaryProtocol] =
        (counts[product.primaryProtocol] ?? 0) + 1;
    }

    return counts;
  },
  {},
);

const categoryCounts = mappedProducts.reduce<Record<string, number>>(
  (counts, product) => {
    const key = product.category?.name ?? "Uncategorized";
    counts[key] = (counts[key] ?? 0) + 1;
    return counts;
  },
  {},
);

const hubCounts = mappedProducts.reduce<Record<string, number>>(
  (counts, product) => {
    for (const hubSlug of product.compatibleHubSlugs) {
      counts[hubSlug] = (counts[hubSlug] ?? 0) + 1;
    }

    return counts;
  },
  {},
);

const hubLookup = new Map(hubs.hubs.map((hub) => [hub.slug, hub]));
const compatibleHubs = Object.entries(hubCounts)
  .map(([hubSlug, count]) => ({
    hub: hubLookup.get(hubSlug),
    count,
  }))
  .filter((entry): entry is { hub: HubSummary; count: number } =>
    Boolean(entry.hub),
  )
  .sort((left, right) => right.count - left.count);

const relatedManufacturers = manufacturers.manufacturers
  .filter((candidate) => candidate.slug !== manufacturer.slug)
  .map((candidate) => {
    const candidateProducts = products.products.filter(
      (product) => product.manufacturer?.slug === candidate.slug,
    );
    const candidateProtocols = new Set(
      candidateProducts
        .map((product) => product.primaryProtocol)
        .filter((protocol): protocol is string => Boolean(protocol)),
    );
    const sharedProtocols = [...candidateProtocols].filter(
      (protocol) => protocolCounts[protocol] != null,
    );

    return {
      ...candidate,
      sharedProtocols,
    };
  })
  .sort((left, right) => {
    if (left.sharedProtocols.length !== right.sharedProtocols.length) {
      return right.sharedProtocols.length - left.sharedProtocols.length;
    }

    return right.deviceCount - left.deviceCount;
  })
  .slice(0, 4);

const protocolBreakdown = Object.entries(protocolCounts).sort(
  (left, right) => right[1] - left[1],
);
const categoryBreakdown = Object.entries(categoryCounts).sort(
  (left, right) => right[1] - left[1],
);

const formatCount = new Intl.NumberFormat("en-US");
const categoryColumns = [
  { key: "category", label: "Category" },
  { key: "share", label: "" },
  { key: "devices", label: "Devices", align: "right" as const },
];

const initials = manufacturer.name
  .split(/[\s-]+/)
  .map((part) => part[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
const updatedLabel = manufacturer.updatedAt
  ? new Date(manufacturer.updatedAt).toLocaleDateString("en-US", {
      dateStyle: "medium",
    })
  : "Unknown";
const compatibleHubItems = compatibleHubs.map((entry) => ({
  href: `/hubs/${entry.hub.slug}`,
  label: entry.hub.name,
  icon: "H",
  meta: entry.hub.manufacturer?.name ?? "Independent",
  count: formatCount.format(entry.count),
}));
const relatedManufacturerItems = relatedManufacturers.map((candidate) => ({
  href: `/manufacturers/${candidate.slug}`,
  label: candidate.name,
  icon: candidate.name
    .split(/[\s-]+/)
    .map((part) => part[0])
    .join("")
    .slice(0, 2)
    .toUpperCase(),
  meta:
    candidate.sharedProtocols.length > 0
      ? candidate.sharedProtocols
          .map((protocol) => formatProtocolLabel(protocol))
          .join(", ")
      : "No shared protocols listed",
  count: formatCount.format(candidate.deviceCount),
}));
const summaryText =
  protocolBreakdown.length > 0
    ? `${manufacturer.name} currently includes ${manufacturer.deviceCount} device${manufacturer.deviceCount === 1 ? "" : "s"} across ${protocolBreakdown.length} protocol ${protocolBreakdown.length === 1 ? "family" : "families"} in the catalog.`
    : `${manufacturer.name} currently includes ${manufacturer.deviceCount} device${manufacturer.deviceCount === 1 ? "" : "s"} in the catalog.`;
const heroDescription = `${summaryText} ${
  manufacturer.website
    ? `Official website: ${manufacturer.website.replace(/^https?:\/\//, "")}.`
    : "An official website is not listed for this brand."
}`;
const featureCounts = Object.fromEntries(
  catalogPayload.facets.features.map((feature) => [feature.key, feature.count]),
) as {
  localControl: number;
  matterCertified: number;
  noCloud: number;
  noHub: number;
};
const initialCatalog = getCatalogResults(
  catalogPayload,
  createDefaultCatalogState(),
  "",
  { manufacturers: [manufacturer.slug] },
  12,
);
---

<BaseLayout
  title={`${manufacturer.name} | SmartPicker`}
  description={`${manufacturer.name} device coverage, protocol breakdown, and hub compatibility in SmartPicker.`}
>
  <div class="mx-auto max-w-[1200px] px-6">
    <Breadcrumbs
      items={[
        { href: "/", label: "Home" },
        { href: "/manufacturers", label: "Manufacturers" },
        { label: manufacturer.name },
      ]}
    />

    <EntityDetailHero
      class="animate-fade-in pb-6"
      icon={initials}
      title={manufacturer.name}
      description={heroDescription}
      badges={protocolBreakdown.length > 0
        ? protocolBreakdown.map(([protocol]) => {
            const style = getProtocolStyle(protocol);

            return {
              label: formatProtocolLabel(protocol),
              class: `${style.badge} ${style.text} border-badge`,
            };
          })
        : [{ label: "No protocol mapping yet" }]}
      statsWrapperClass="max-w-[760px]"
      statsColumnsClass="grid-cols-3 max-md:grid-cols-1"
      stats={[
        {
          value: formatCount.format(manufacturer.deviceCount),
          label: "Total devices",
        },
        {
          value: formatCount.format(
            mappedProducts.filter((product) =>
              product.compatibilityStatuses.includes("verified"),
            ).length,
          ),
          label: "Verified",
        },
        {
          value: formatCount.format(categoryBreakdown.length),
          label: "Categories",
        },
      ]}
    />

    <div class="mt-[-4px] pb-6">
      <div class="h-2 overflow-hidden rounded-full bg-[var(--sp-bar-track)]">
        {
          protocolBreakdown.map(([protocol, count]) => {
            const style = getProtocolStyle(protocol);
            return (
              <div
                class:list={["inline-block h-full", style.badge]}
                style={`width:${(count / Math.max(manufacturer.deviceCount, 1)) * 100}%`}
              />
            );
          })
        }
      </div>
      <div class="mt-3 flex flex-wrap gap-3">
        {
          protocolBreakdown.map(([protocol, count]) => {
            const style = getProtocolStyle(protocol);

            return (
              <span class="text-secondary inline-flex items-center gap-2 text-sm">
                <span
                  class:list={[
                    "inline-flex h-2.5 w-2.5 rounded-full",
                    style.badge,
                  ]}
                />
                {formatProtocolLabel(protocol)}
                <span class="text-muted font-mono text-xs">{count}</span>
              </span>
            );
          })
        }
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
      <div class="flex flex-col gap-6">
        <section>
          <SectionHeader
            eyebrow="Protocol breakdown"
            title="Coverage by protocol"
          />
          <div
            class="grid [grid-template-columns:repeat(auto-fit,minmax(260px,1fr))] gap-4"
          >
            {
              protocolBreakdown.map(([protocol, count], index) => (
                <div style={`animation-delay:${0.05 + index * 0.05}s`}>
                  <ManufacturerProtocolCard
                    protocol={protocol}
                    count={formatCount.format(count)}
                    devices={formatCount.format(
                      mappedProducts.filter(
                        (product) => product.primaryProtocol === protocol,
                      ).length,
                    )}
                    reported={formatCount.format(
                      mappedProducts.filter(
                        (product) =>
                          product.primaryProtocol === protocol &&
                          product.compatibilityStatuses.includes("reported"),
                      ).length,
                    )}
                    percentage={
                      (count / Math.max(manufacturer.deviceCount, 1)) * 100
                    }
                  />
                </div>
              ))
            }
          </div>
        </section>

        <DataTableSection
          class="animate-fade-in"
          title="Device Categories"
          summaryLabel={`${formatCount.format(manufacturer.deviceCount)} total`}
          columns={categoryColumns}
          rows={categoryBreakdown}
          mobileMode="scroll"
          cellComponent={ManufacturerCategoryTableCell}
          cellProps={{ total: manufacturer.deviceCount }}
        />

        <section>
          <div
            class="text-muted mb-4 text-[13px] font-semibold tracking-wider uppercase"
          >
            Popular Devices
          </div>
          <div
            class="grid grid-cols-3 gap-3 max-lg:grid-cols-2 max-md:grid-cols-1"
          >
            {
              mappedProducts.slice(0, 6).map((product, index) => {
                const style = product.primaryProtocol
                  ? getProtocolStyle(product.primaryProtocol)
                  : { badge: "bg-badge", text: "text-secondary" };

                return (
                  <a
                    href={`/devices/${product.slug}`}
                    class="card-hover border-theme bg-surface text-primary flex flex-col rounded-2xl border p-5"
                    style={`animation-delay:${0.25 + index * 0.05}s`}
                  >
                    <div class="mb-3.5 flex items-start justify-between">
                      <div class="bg-elevated text-muted flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-[10px] text-sm font-semibold">
                        {product.model?.slice(0, 2).toUpperCase() ?? "SP"}
                      </div>
                      <span
                        class={`rounded-full px-2 py-0.5 text-[10px] font-bold tracking-wide uppercase ${style.badge} ${style.text}`}
                      >
                        {formatProtocolLabel(product.primaryProtocol)}
                      </span>
                    </div>
                    <div class="mb-0.5 text-[15px] leading-tight font-semibold">
                      {product.name}
                    </div>
                    <div class="text-muted mb-3 text-[13px]">
                      {product.model ?? "Model TBD"}
                    </div>
                    <div class="border-theme mt-2.5 flex items-center gap-1 border-t pt-2.5">
                      <span class="bg-green-subtle text-green flex h-[18px] w-[18px] items-center justify-center rounded-full text-[9px] font-bold">
                        {product.compatibleHubSlugs.length}
                      </span>
                      <span class="text-muted ml-auto text-[11px]">
                        {product.compatibleHubSlugs.length} hub
                        {product.compatibleHubSlugs.length === 1 ? "" : "s"}
                      </span>
                    </div>
                  </a>
                );
              })
            }
          </div>
        </section>
      </div>

      <aside class="flex flex-col gap-6 max-lg:order-first">
        <div class="animate-fade-in" style="animation-delay:0.1s">
          <DetailSidebarCard
            title="Company Info"
            rows={[
              {
                label: "Slug",
                value: manufacturer.slug,
                mono: true,
              },
              {
                label: "Website",
                value: manufacturer.website
                  ? manufacturer.website.replace(/^https?:\/\//, "")
                  : "Not listed",
                href: manufacturer.website,
                external: Boolean(manufacturer.website),
              },
              {
                label: "Devices tracked",
                value: formatCount.format(manufacturer.deviceCount),
                mono: true,
              },
              {
                label: "Protocols",
                value: formatCount.format(protocolBreakdown.length),
              },
              {
                label: "Last updated",
                value: updatedLabel,
              },
            ]}
          />
        </div>

        <div class="animate-fade-in" style="animation-delay:0.15s">
          <SidebarPanel title="Official Links">
            {
              manufacturer.website ? (
                <a
                  href={manufacturer.website}
                  target="_blank"
                  rel="noreferrer"
                  class="border-theme bg-elevated text-primary hover:border-theme-hover flex items-center gap-3 rounded-2xl border px-4 py-3 transition-all hover:-translate-y-0.5"
                >
                  <span class="bg-surface inline-flex h-8 w-8 items-center justify-center rounded-lg text-sm">
                    🌐
                  </span>
                  {manufacturer.website.replace(/^https?:\/\//, "")}
                </a>
              ) : (
                <p class="text-muted text-[13px] leading-relaxed">
                  No official website is listed for this manufacturer.
                </p>
              )
            }
          </SidebarPanel>
        </div>

        <div class="animate-fade-in" style="animation-delay:0.2s">
          <EntityLinkList
            title="Compatible Hubs"
            items={compatibleHubItems}
            emptyText="No compatible hubs are listed for this manufacturer yet."
          />
        </div>

        <div class="animate-fade-in" style="animation-delay:0.25s">
          <EntityLinkList
            title="Similar Manufacturers"
            items={relatedManufacturerItems}
            emptyText="No related manufacturers are listed right now."
          />
        </div>

        <ButtonLink
          href={`/devices?manufacturer=${encodeURIComponent(manufacturer.slug)}`}
          variant="secondary"
          class="justify-center"
        >
          Browse all {formatCount.format(manufacturer.deviceCount)} devices →
        </ButtonLink>
      </aside>
    </div>

    <CatalogSection
      title={`Browse ${manufacturer.name} devices`}
      description="Browse devices from this manufacturer and refine the results by protocol or key features."
      initialCatalog={{
        products: initialCatalog.pagedProducts,
        totalCount: initialCatalog.filteredProducts.length,
        totalPages: initialCatalog.totalPages,
        page: initialCatalog.safePage,
        from: initialCatalog.from,
        to: initialCatalog.to,
      }}
      initialFacets={{
        protocols: catalogPayload.facets.protocols,
        manufacturers: catalogPayload.facets.manufacturers,
        categories: catalogPayload.facets.categories,
        integrations: catalogPayload.facets.integrations,
        platforms: catalogPayload.facets.platforms,
        hubs: catalogPayload.facets.hubs,
        featureCounts,
      }}
      uiConfig={{
        hiddenSections: { manufacturers: true },
        lockedFilters: { manufacturers: [manufacturer.slug] },
      }}
    />
  </div>
</BaseLayout>
