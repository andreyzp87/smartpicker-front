---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeFeaturedDeviceCard from "../components/home/HomeFeaturedDeviceCard.astro";
import HomeHero from "../components/home/HomeHero.astro";
import HomeHubCard from "../components/home/HomeHubCard.astro";
import HomeManufacturerCard from "../components/home/HomeManufacturerCard.astro";
import HomeProtocolCard from "../components/home/HomeProtocolCard.astro";
import HomeSnapshotCta from "../components/home/HomeSnapshotCta.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import { readExportJson } from "../lib/exports";

interface SiteExport {
  generated: string;
  stats: {
    devices: number;
    hubs: number;
    manufacturers: number;
    categories: number;
    protocols: number;
  };
  featuredDeviceSlugs: string[];
  recentlyUpdatedDeviceSlugs: string[];
}

interface ProductSummary {
  slug: string;
  name: string;
  model: string | null;
  primaryProtocol: string | null;
  localControl: boolean | null;
  cloudDependent: boolean | null;
  requiresHub: boolean | null;
  manufacturer: {
    slug: string;
    name: string;
  } | null;
  compatibleHubSlugs: string[];
  compatibilityStatuses: string[];
  updatedAt: string;
}

interface ProductsExport {
  count: number;
  products: ProductSummary[];
}

interface ProtocolSummary {
  slug: string;
  name: string;
  description: string;
  deviceCount: number;
}

interface ProtocolsExport {
  protocols: ProtocolSummary[];
}

interface HubSummary {
  slug: string;
  name: string;
  description: string | null;
  deviceCount: number;
  protocolsSupported: string[];
}

interface HubsExport {
  hubs: HubSummary[];
}

interface ManufacturerSummary {
  slug: string;
  name: string;
  deviceCount: number;
}

interface ManufacturersExport {
  manufacturers: ManufacturerSummary[];
}

const site = await readExportJson<SiteExport>("site.json");
const products = await readExportJson<ProductsExport>("products.json");
const protocols = await readExportJson<ProtocolsExport>("protocols.json");
const hubs = await readExportJson<HubsExport>("hubs.json");
const manufacturers = await readExportJson<ManufacturersExport>(
  "manufacturers.json",
);

const productBySlug = new Map(products.products.map((product) => [product.slug, product]));
const featuredDevices = site.featuredDeviceSlugs
  .map((slug) => productBySlug.get(slug))
  .filter((product): product is ProductSummary => Boolean(product))
  .slice(0, 4);
const recentDevices = site.recentlyUpdatedDeviceSlugs
  .map((slug) => productBySlug.get(slug))
  .filter((product): product is ProductSummary => Boolean(product))
  .slice(0, 3);
const topManufacturers = [...manufacturers.manufacturers]
  .sort((left, right) => right.deviceCount - left.deviceCount)
  .slice(0, 6);

const searchChips = [
  products.products[0]?.manufacturer?.name,
  featuredDevices[0]?.name,
  protocols.protocols.find((protocol) => protocol.deviceCount > 0)?.name,
  recentDevices[0]?.model,
]
  .filter((value): value is string => Boolean(value))
  .slice(0, 4);

const formatCount = new Intl.NumberFormat("en-US");
const generatedLabel = new Date(site.generated).toLocaleString("en-US", {
  dateStyle: "medium",
  timeStyle: "short",
});
const recentDevicesLabel =
  recentDevices.length > 0
    ? recentDevices.map((device) => device.name).join(", ")
    : "the latest published device entries";
---

<BaseLayout
  title="SmartPicker | Find Compatible Smart Home Devices"
  description="Search smart home devices, compare protocol coverage, and explore hub compatibility using SmartPicker export data."
>
  <HomeHero
    indexedDevices={formatCount.format(site.stats.devices)}
    searchChips={searchChips}
    stats={[
      { value: formatCount.format(site.stats.devices), label: "Devices" },
      { value: formatCount.format(site.stats.manufacturers), label: "Manufacturers" },
      { value: formatCount.format(site.stats.hubs), label: "Hubs" },
      { value: formatCount.format(site.stats.protocols), label: "Protocols" },
    ]}
  />

  <section id="protocols" class="mx-auto mt-20 max-w-[1200px] px-6">
    <SectionHeader
      title="Browse by Protocol"
      description="Every protocol export is surfaced here, even when the current snapshot has zero matching devices."
      actionHref="/protocols"
      actionLabel="See all protocols"
    />
    <div class="grid grid-cols-5 gap-3 max-lg:grid-cols-3 max-md:grid-cols-2">
      {
        protocols.protocols.map((protocol) => (
          <HomeProtocolCard
            href={`/protocols/${protocol.slug}`}
            slug={protocol.slug}
            description={protocol.description}
            deviceCount={formatCount.format(protocol.deviceCount)}
          />
        ))
      }
    </div>
  </section>

  <section class="mx-auto mt-16 max-w-[1200px] px-6">
    <SectionHeader
      title="Featured Devices"
      description="Pulled in the same order as `featuredDeviceSlugs` from the current site export."
      actionHref="/devices"
      actionLabel="Browse all"
    />

    <div class="grid grid-cols-4 gap-3 max-lg:grid-cols-2 max-md:grid-cols-1">
      {
        featuredDevices.map((device) => (
          <HomeFeaturedDeviceCard
            href={`/devices/${device.slug}`}
            name={device.name}
            manufacturerName={device.manufacturer?.name ?? "Unknown manufacturer"}
            model={device.model}
            protocolSlug={device.primaryProtocol}
            compatibilityStatus={device.compatibilityStatuses[0] ?? null}
            hubCount={device.compatibleHubSlugs.length}
            requiresHub={device.requiresHub}
            localControl={device.localControl}
            updatedLabel={new Date(device.updatedAt).toLocaleDateString("en-US", {
              dateStyle: "medium",
            })}
          />
        ))
      }
    </div>
  </section>

  <section class="mx-auto mt-16 max-w-[1200px] px-6">
    <SectionHeader
      title="Compatible Hubs & Platforms"
      description="Hub coverage pulled from the exported hub index."
      actionHref="/hubs"
      actionLabel="View all"
    />

    <div class="grid grid-cols-3 gap-3 max-md:grid-cols-1">
      {
        hubs.hubs.map((hub) => (
          <HomeHubCard
            href={`/hubs/${hub.slug}`}
            name={hub.name}
            protocolSlugs={hub.protocolsSupported}
            description={hub.description}
            deviceCount={formatCount.format(hub.deviceCount)}
          />
        ))
      }
    </div>
  </section>

  <section id="manufacturers" class="mx-auto mt-16 max-w-[1200px] px-6">
    <SectionHeader
      title="Manufacturers in This Snapshot"
      description="Category exports are still empty, so the home page highlights the brands currently represented in `manufacturers.json`."
      actionHref="/devices"
      actionLabel="Explore devices"
    />

    <div class="grid grid-cols-3 gap-3 max-lg:grid-cols-2 max-md:grid-cols-1">
      {
        topManufacturers.map((manufacturer) => (
          <HomeManufacturerCard
            href={`/manufacturers/${manufacturer.slug}`}
            name={manufacturer.name}
            deviceCount={formatCount.format(manufacturer.deviceCount)}
            initials={manufacturer.name
              .split(" ")
              .slice(0, 2)
              .map((part) => part[0])
              .join("")
              .slice(0, 2)
              .toUpperCase()}
          />
        ))
      }
    </div>
  </section>

  <HomeSnapshotCta
    generatedLabel={generatedLabel}
    recentDevicesLabel={recentDevicesLabel}
  />
</BaseLayout>
