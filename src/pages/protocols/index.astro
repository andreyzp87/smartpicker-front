---
import type { ProtocolsResponse } from "../../../data/exports/types";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProtocolSummaryCard from "../../components/protocols/ProtocolSummaryCard.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import PageIntro from "../../components/ui/PageIntro.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import { readExportJson } from "../../lib/exports";
import { getProtocolStyle } from "../../lib/ui";

const protocols = await readExportJson<ProtocolsResponse>("protocols.json");
const sortedProtocols = [...protocols.protocols].sort((left, right) =>
  right.deviceCount === left.deviceCount
    ? left.name.localeCompare(right.name)
    : right.deviceCount - left.deviceCount,
);
const activeProtocolCount = sortedProtocols.filter(
  (protocol) => protocol.deviceCount > 0,
).length;
const spotlightProtocol = sortedProtocols[0] ?? null;
const totalDeviceCount = sortedProtocols.reduce(
  (sum, protocol) => sum + protocol.deviceCount,
  0,
);
const formatCount = new Intl.NumberFormat("en-US");
---

<BaseLayout
  title="Protocols | SmartPicker"
  description="Compare smart home protocols by device coverage, integrations, platforms, and commercial hub counts."
>
  <div class="mx-auto max-w-[1200px] px-6">
    <PageIntro
      title="Protocols"
      description="Understand the wireless and ecosystem standards behind the catalog, then use protocol pages to move from device coverage to integrations, platforms, and commercial hubs."
      stats={[
        {
          value: formatCount.format(protocols.count),
          label: "Protocol families",
        },
        {
          value: formatCount.format(activeProtocolCount),
          label: "With mapped devices",
        },
        {
          value: formatCount.format(
            sortedProtocols.reduce(
              (sum, protocol) => sum + protocol.integrationCount,
              0,
            ),
          ),
          label: "Integration links",
        },
        {
          value: formatCount.format(
            sortedProtocols.reduce((sum, protocol) => sum + protocol.hubCount, 0),
          ),
          label: "Commercial hubs",
        },
      ]}
    />

    {
      spotlightProtocol && (
        <section class="mb-10 grid gap-5 rounded-2xl border border-theme bg-surface p-6 shadow-card lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)]">
          <div class="flex flex-col gap-4">
            <div class="flex items-start gap-4">
              <div class:list={[
                "flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl border border-badge text-xl font-bold tracking-[-0.04em]",
                getProtocolStyle(spotlightProtocol.slug).badge,
                getProtocolStyle(spotlightProtocol.slug).text,
              ]}>
                {getProtocolStyle(spotlightProtocol.slug).shortLabel}
              </div>
              <div class="min-w-0 flex-1">
                <SectionHeader eyebrow="Protocol highlight" title={spotlightProtocol.title} />
                <p class="mt-3 max-w-[700px] text-sm leading-relaxed text-secondary">
                  {spotlightProtocol.description}
                </p>
              </div>
            </div>

            <div class="h-2 overflow-hidden rounded-full bg-[var(--sp-bar-track)]">
              <div
                class:list={[
                  "h-full rounded-full",
                  getProtocolStyle(spotlightProtocol.slug).badge,
                ]}
                style={`width:${totalDeviceCount > 0 ? (spotlightProtocol.deviceCount / totalDeviceCount) * 100 : 0}%`}
              >
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3 max-md:grid-cols-1">
            <div class="rounded-2xl border border-theme bg-elevated p-4">
              <div class="text-lg font-bold font-mono tracking-tight">
                {formatCount.format(spotlightProtocol.deviceCount)}
              </div>
              <div class="text-[11px] tracking-wider uppercase text-muted">
                Devices
              </div>
            </div>
            <div class="rounded-2xl border border-theme bg-elevated p-4">
              <div class="text-lg font-bold font-mono tracking-tight">
                {formatCount.format(spotlightProtocol.integrationCount)}
              </div>
              <div class="text-[11px] tracking-wider uppercase text-muted">
                Integrations
              </div>
            </div>
            <div class="rounded-2xl border border-theme bg-elevated p-4">
              <div class="text-lg font-bold font-mono tracking-tight">
                {formatCount.format(spotlightProtocol.platformCount)}
              </div>
              <div class="text-[11px] tracking-wider uppercase text-muted">
                Platforms
              </div>
            </div>
            <div class="rounded-2xl border border-theme bg-elevated p-4">
              <div class="text-lg font-bold font-mono tracking-tight">
                {formatCount.format(spotlightProtocol.hubCount)}
              </div>
              <div class="text-[11px] tracking-wider uppercase text-muted">
                Hubs
              </div>
            </div>
          </div>
        </section>
      )
    }

    {
      sortedProtocols.length > 0 ? (
        <section class="grid gap-4 pb-20 [grid-template-columns:repeat(auto-fit,minmax(280px,1fr))]">
          {sortedProtocols.map((protocol) => (
            <ProtocolSummaryCard
              href={`/protocols/${protocol.slug}`}
              slug={protocol.slug}
              name={protocol.name}
              description={protocol.description}
              deviceCount={formatCount.format(protocol.deviceCount)}
              integrationCount={formatCount.format(protocol.integrationCount)}
              platformCount={formatCount.format(protocol.platformCount)}
              hubCount={formatCount.format(protocol.hubCount)}
              deviceShare={totalDeviceCount > 0 ? (protocol.deviceCount / totalDeviceCount) * 100 : 0}
            />
          ))}
        </section>
      ) : (
        <div class="pb-20">
          <EmptyState
            title="No protocols available yet"
            description="Protocol pages will appear here as coverage is added to the catalog."
          />
        </div>
      )
    }
  </div>
</BaseLayout>
