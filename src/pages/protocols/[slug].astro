---
import type {
  HubsResponse,
  IntegrationsResponse,
  PlatformsResponse,
  ProductsIndexResponse,
  ProtocolDetailResponse,
  ProtocolSlugsResponse,
} from "../../../data/exports/types";
import CatalogSection from "../../components/devices/CatalogSection.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import EntityDetailHero from "../../components/ui/EntityDetailHero.astro";
import EntityCardGridSection from "../../components/ui/EntityCardGridSection.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import MetricCardGrid from "../../components/ui/MetricCardGrid.astro";
import ProtocolBadge from "../../components/ui/ProtocolBadge.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import {
  createDefaultCatalogState,
  getCatalogResults,
} from "../../lib/catalog/core";
import { getCatalogPayload } from "../../lib/catalog/server";
import { readExportJson } from "../../lib/exports";
import { getProtocolStyle } from "../../lib/ui";

export async function getStaticPaths() {
  const { slugs } = await readExportJson<ProtocolSlugsResponse>(
    "protocols/slugs.json",
  );

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Protocol slug is required.");
}

const [detail, products, integrations, platforms, hubs, catalogPayload] =
  await Promise.all([
    readExportJson<ProtocolDetailResponse>(`protocols/${slug}.json`),
    readExportJson<ProductsIndexResponse>("products.json"),
    readExportJson<IntegrationsResponse>("integrations.json"),
    readExportJson<PlatformsResponse>("platforms.json"),
    readExportJson<HubsResponse>("hubs.json"),
    getCatalogPayload(),
  ]);

const protocol = detail.protocol;
const productBySlug = new Map(
  products.products.map((product) => [product.slug, product]),
);
const integrationBySlug = new Map(
  integrations.integrations.map((integration) => [
    integration.slug,
    integration,
  ]),
);
const platformBySlug = new Map(
  platforms.platforms.map((platform) => [platform.slug, platform]),
);
const hubBySlug = new Map(hubs.hubs.map((hub) => [hub.slug, hub]));

const mappedProducts = protocol.deviceSlugs
  .map((deviceSlug) => productBySlug.get(deviceSlug))
  .filter((product): product is ProductsIndexResponse["products"][number] =>
    Boolean(product),
  );
const linkedIntegrations = protocol.integrationSlugs
  .map((integrationSlug) => integrationBySlug.get(integrationSlug))
  .filter(
    (
      integration,
    ): integration is IntegrationsResponse["integrations"][number] =>
      Boolean(integration),
  );
const linkedPlatforms = protocol.platformSlugs
  .map((platformSlug) => platformBySlug.get(platformSlug))
  .filter((platform): platform is PlatformsResponse["platforms"][number] =>
    Boolean(platform),
  );
const linkedHubs = protocol.hubSlugs
  .map((hubSlug) => hubBySlug.get(hubSlug))
  .filter((hub): hub is HubsResponse["hubs"][number] => Boolean(hub));

const manufacturerCount = new Set(
  mappedProducts.map((product) => product.manufacturer?.slug).filter(Boolean),
).size;
const featureCounts = Object.fromEntries(
  catalogPayload.facets.features.map((feature) => [feature.key, feature.count]),
) as {
  localControl: number;
  matterCertified: number;
  noCloud: number;
  noHub: number;
};
const initialCatalog = getCatalogResults(
  catalogPayload,
  createDefaultCatalogState(),
  "",
  { protocols: [protocol.slug] },
  20,
);
const style = getProtocolStyle(protocol.slug);
const formatCount = new Intl.NumberFormat("en-US");
const updatedLabel = protocol.updatedAt
  ? new Date(protocol.updatedAt).toLocaleDateString("en-US", {
      dateStyle: "medium",
    })
  : "Awaiting first refresh";
const linkedIntegrationCards = linkedIntegrations.map((integration) => ({
  href: `/integrations/${integration.slug}`,
  title: integration.name,
  meta: `${formatCount.format(integration.compatibleDeviceCount)} compatible devices`,
}));
const linkedPlatformCards = linkedPlatforms.map((platform) => ({
  href: `/platforms/${platform.slug}`,
  title: platform.name,
  meta: `${formatCount.format(platform.compatibleDeviceCountDerived)} supported devices`,
}));
const linkedHubCards = linkedHubs.map((hub) => ({
  href: `/hubs/${hub.slug}`,
  title: hub.name,
  meta: `${hub.manufacturer?.name ?? "Independent"} · ${formatCount.format(hub.compatibleDeviceCount)} compatible devices`,
}));
const snapshotMetrics = [
  {
    value: formatCount.format(protocol.deviceCount),
    label: "Devices",
  },
  {
    value: formatCount.format(manufacturerCount),
    label: "Manufacturers",
  },
  {
    value: formatCount.format(protocol.integrationCount),
    label: "Direct integrations",
  },
  {
    value: formatCount.format(protocol.platformCount),
    label: "Derived platforms",
  },
];
---

<BaseLayout
  title={`${protocol.name} | SmartPicker`}
  description={`${protocol.name} device, integration, platform, and commercial hub coverage in SmartPicker.`}
>
  <div class="mx-auto max-w-[1200px] px-6">
    <Breadcrumbs
      items={[
        { href: "/", label: "Home" },
        { href: "/protocols", label: "Protocols" },
        { label: protocol.name },
      ]}
    />

    <EntityDetailHero
      pretitle="Protocol detail"
      title={protocol.title}
      description={protocol.description}
      stats={[]}
    >
      <div
        slot="icon"
        class:list={[
          "border-badge flex h-20 w-20 items-center justify-center rounded-2xl border text-xl font-bold tracking-[-0.04em]",
          style.badge,
          style.text,
        ]}
      >
        {style.shortLabel}
      </div>
      <ProtocolBadge slot="badges" slug={protocol.slug} class="rounded-md" />
      <span
        slot="badges"
        class="border-theme bg-badge text-secondary rounded-md border px-3 py-1 text-[13px] font-medium"
      >
        Updated {updatedLabel}
      </span>
    </EntityDetailHero>

    <div class="grid gap-6 pb-20 lg:grid-cols-[minmax(0,1.55fr)_320px]">
      <div class="flex flex-col gap-6">
        <section>
          <SectionHeader
            eyebrow="Coverage"
            title="Protocol snapshot"
            description="See how this protocol shows up across devices, brands, and the software ecosystems built around it."
          />
          <MetricCardGrid
            items={snapshotMetrics}
            tone="accent"
            gridCols="md:grid-cols-4"
          />
        </section>

        <EntityCardGridSection
          eyebrow="Integrations"
          title="Top integrations using this protocol"
          description="Popular integrations that support devices using this protocol."
          items={linkedIntegrationCards}
          emptyText="No integrations are listed for this protocol yet."
        />

        <EntityCardGridSection
          eyebrow="Platforms"
          title="Platform coverage"
          description="Platforms appear here when linked integrations expose compatibility through them."
          items={linkedPlatformCards}
          emptyText="No platforms are listed for this protocol yet."
        />

        <EntityCardGridSection
          eyebrow="Commercial Hubs"
          title="Hub counts where relevant"
          description="Commercial hubs are shown separately, so dedicated ecosystems stay easy to compare."
          items={linkedHubCards}
          emptyText="No commercial hubs are listed for this protocol yet."
        />
      </div>

      <aside class="flex flex-col gap-6">
        {
          mappedProducts.length > 0 ? (
            <div class="border-theme bg-surface rounded-2xl border p-5">
              <h2 class="text-primary text-lg font-semibold tracking-tight">
                Sample devices
              </h2>
              <div class="mt-4 flex flex-col gap-3">
                {mappedProducts.slice(0, 6).map((product) => (
                  <a
                    href={`/devices/${product.slug}`}
                    class="border-theme bg-elevated text-secondary hover:border-theme-hover hover:text-primary rounded-xl border px-4 py-3 text-sm transition-all"
                  >
                    {product.name}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <EmptyState
              title="No devices for this protocol"
              description="Device coverage for this protocol has not been added yet."
            />
          )
        }
      </aside>
    </div>

    <CatalogSection
      title={`Browse ${protocol.name} devices`}
      description="Browse devices for this protocol and refine the results by manufacturer, category, integration, platform, hub, or key features."
      initialCatalog={{
        products: initialCatalog.pagedProducts,
        totalCount: initialCatalog.filteredProducts.length,
        totalPages: initialCatalog.totalPages,
        page: initialCatalog.safePage,
        from: initialCatalog.from,
        to: initialCatalog.to,
      }}
      initialFacets={{
        protocols: catalogPayload.facets.protocols,
        manufacturers: catalogPayload.facets.manufacturers,
        categories: catalogPayload.facets.categories,
        integrations: catalogPayload.facets.integrations,
        platforms: catalogPayload.facets.platforms,
        hubs: catalogPayload.facets.hubs,
        featureCounts,
      }}
      uiConfig={{
        hiddenSections: { protocols: true },
        lockedFilters: { protocols: [protocol.slug] },
      }}
    />
  </div>
</BaseLayout>
