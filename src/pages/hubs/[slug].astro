---
import type {
  HubDetailResponse,
  HubSlugsResponse,
  HubsResponse,
  ProductsIndexResponse,
} from "../../../data/exports/types";
import CatalogSection from "../../components/devices/CatalogSection.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HubCoverageCard from "../../components/hubs/HubCoverageCard.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import DetailSidebarCard from "../../components/ui/DetailSidebarCard.astro";
import EntityDetailHero from "../../components/ui/EntityDetailHero.astro";
import EntityLinkList from "../../components/ui/EntityLinkList.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import {
  createDefaultCatalogState,
  getCatalogResults,
} from "../../lib/catalog/core";
import { getCatalogPayload } from "../../lib/catalog/server";
import { readExportJson } from "../../lib/exports";
import { getProtocolStyle } from "../../lib/ui";

export async function getStaticPaths() {
  const { slugs } = await readExportJson<HubSlugsResponse>("hubs/slugs.json");

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing hub slug.");
}

const [detail, products, allHubs, catalogPayload] = await Promise.all([
  readExportJson<HubDetailResponse>(`hubs/${slug}.json`),
  readExportJson<ProductsIndexResponse>("products.json"),
  readExportJson<HubsResponse>("hubs.json"),
  getCatalogPayload(),
]);

const hub = detail.hub;
const mappedDevices = products.products.filter((product) =>
  hub.compatibleDeviceSlugs.includes(product.slug),
);
const deriveProtocolCounts = (deviceList: ProductsIndexResponse["products"]) =>
  deviceList.reduce<Record<string, number>>((counts, product) => {
    if (product.primaryProtocol) {
      counts[product.primaryProtocol] =
        (counts[product.primaryProtocol] ?? 0) + 1;
    }

    return counts;
  }, {});
const protocolCounts = deriveProtocolCounts(mappedDevices);
const protocolsSupported = Object.keys(protocolCounts);
const relatedHubs = allHubs.hubs
  .filter((candidate) => candidate.slug !== hub.slug)
  .map((candidate) => ({
    ...candidate,
    sharedProtocolCount: 0,
  }))
  .sort((left, right) => {
    if (left.sharedProtocolCount !== right.sharedProtocolCount) {
      return right.sharedProtocolCount - left.sharedProtocolCount;
    }

    return right.compatibleDeviceCount - left.compatibleDeviceCount;
  })
  .slice(0, 4);
const featureCounts = Object.fromEntries(
  catalogPayload.facets.features.map((feature) => [feature.key, feature.count]),
) as {
  localControl: number;
  matterCertified: number;
  noCloud: number;
  noHub: number;
};
const initialCatalog = getCatalogResults(
  catalogPayload,
  createDefaultCatalogState(),
  "",
  { hubs: [hub.slug] },
  20,
);
const formatCount = new Intl.NumberFormat("en-US");
const updatedLabel = hub.updatedAt
  ? new Date(hub.updatedAt).toLocaleDateString("en-US", { dateStyle: "medium" })
  : "Unknown";
const relatedHubItems = relatedHubs.map((candidate) => ({
  href: `/hubs/${candidate.slug}`,
  label: candidate.name,
}));
const description =
  hub.description ??
  `${hub.name} supports ${hub.compatibleDeviceCount} compatible device${hub.compatibleDeviceCount === 1 ? "" : "s"} in SmartPicker.`;
---

<BaseLayout
  title={`${hub.name} | SmartPicker`}
  description={`${hub.name} compatible devices and commercial hub coverage in SmartPicker.`}
>
  <div class="mx-auto max-w-[1200px] px-6">
    <Breadcrumbs
      items={[
        { href: "/", label: "Home" },
        { href: "/hubs", label: "Hubs" },
        { label: hub.name },
      ]}
    />

    <EntityDetailHero
      title={hub.name}
      description={description}
      statsWrapperClass="max-w-[760px]"
      statsColumnsClass="grid-cols-4 max-md:grid-cols-2"
      stats={[
        {
          value: formatCount.format(hub.compatibleDeviceCount),
          label: "Devices",
        },
        {
          value: formatCount.format(protocolsSupported.length),
          label: "Protocols",
        },
        {
          value: formatCount.format(hub.statusBreakdown.verified ?? 0),
          label: "Verified",
        },
        { value: updatedLabel, label: "Updated", muted: true },
      ]}
    >
      <div
        slot="icon"
        class="border-theme bg-elevated text-secondary flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl border text-[34px] font-semibold"
      >
        H
      </div>
      {
        protocolsSupported.map((protocol) => (
          <span
            slot="badges"
            class:list={[
              "inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-[11px] font-semibold",
              getProtocolStyle(protocol).badge,
              getProtocolStyle(protocol).text,
            ]}
          >
            {protocol}
          </span>
        ))
      }
    </EntityDetailHero>

    <div class="grid gap-6 pb-20 lg:grid-cols-[minmax(0,1.55fr)_320px]">
      <div class="flex flex-col gap-6">
        <section>
          <SectionHeader
            eyebrow="Protocol coverage"
            title="Coverage by protocol"
          />
          <div
            class="grid [grid-template-columns:repeat(auto-fit,minmax(260px,1fr))] gap-4"
          >
            {
              protocolsSupported.length > 0 ? (
                protocolsSupported.map((protocol) => {
                  const count = protocolCounts[protocol] ?? 0;
                  const width =
                    hub.compatibleDeviceCount > 0
                      ? Math.max(
                          (count / hub.compatibleDeviceCount) * 100,
                          count > 0 ? 8 : 0,
                        )
                      : 0;

                  return (
                    <HubCoverageCard
                      protocol={protocol}
                      count={formatCount.format(count)}
                      verified={formatCount.format(
                        hub.statusBreakdown.verified ?? 0,
                      )}
                      reported={formatCount.format(
                        hub.statusBreakdown.reported ?? 0,
                      )}
                      untested={formatCount.format(
                        hub.statusBreakdown.untested ?? 0,
                      )}
                      width={width}
                    />
                  );
                })
              ) : (
                <div class="border-theme bg-surface text-muted rounded-2xl border px-5 py-6 text-sm">
                  Protocol coverage is not available for this hub yet.
                </div>
              )
            }
          </div>
        </section>

        <section
          class="border-theme bg-surface overflow-hidden rounded-2xl border"
        >
          <div
            class="border-theme flex items-center justify-between border-b px-6 py-5"
          >
            <h2 class="text-2xl font-semibold tracking-tight">
              Compatible Devices
            </h2>
            <span class="text-muted text-[13px]">
              {formatCount.format(mappedDevices.length)} shown for this hub
            </span>
          </div>
          <div class="grid gap-px bg-[var(--sp-border)] md:grid-cols-2">
            {
              mappedDevices.length > 0 ? (
                mappedDevices.map((device) => {
                  const style = getProtocolStyle(device.primaryProtocol);

                  return (
                    <a
                      href={`/devices/${device.slug}`}
                      class="bg-surface text-primary flex items-center gap-3 px-5 py-4 transition-colors hover:bg-[var(--sp-table-row-hover)]"
                    >
                      <div class="bg-elevated text-muted flex h-11 w-11 shrink-0 items-center justify-center rounded-lg text-sm font-semibold">
                        {style.shortLabel}
                      </div>
                      <div class="min-w-0 flex-1">
                        <div class="overflow-hidden text-sm font-medium text-ellipsis whitespace-nowrap">
                          {device.name}
                        </div>
                        <div class="text-muted text-xs">
                          {device.manufacturer?.name ?? "Unknown manufacturer"}{" "}
                          · {device.model ?? "Model TBD"}
                        </div>
                      </div>
                    </a>
                  );
                })
              ) : (
                <div class="text-muted px-6 py-6 text-sm md:col-span-2">
                  No compatible devices are listed for this hub yet.
                </div>
              )
            }
          </div>
        </section>
      </div>

      <aside class="flex flex-col gap-6">
        <DetailSidebarCard
          title="Hub info"
          rows={[
            {
              label: "Manufacturer",
              value: hub.manufacturer?.name ?? "Independent",
            },
            {
              label: "Website",
              value: hub.website
                ? hub.website.replace(/^https?:\/\//, "")
                : "Not listed",
              href: hub.website,
              external: Boolean(hub.website),
            },
            {
              label: "Updated",
              value: updatedLabel,
            },
          ]}
        />

        <EntityLinkList
          title="Related hubs"
          items={relatedHubItems}
          emptyText="No related hubs are listed right now."
        />
      </aside>
    </div>

    <CatalogSection
      title={`Browse devices for ${hub.name}`}
      description="Browse devices currently associated with this commercial hub and refine by protocol, manufacturer, category, integration, platform, or key features."
      initialCatalog={{
        products: initialCatalog.pagedProducts,
        totalCount: initialCatalog.filteredProducts.length,
        totalPages: initialCatalog.totalPages,
        page: initialCatalog.safePage,
        from: initialCatalog.from,
        to: initialCatalog.to,
      }}
      initialFacets={{
        protocols: catalogPayload.facets.protocols,
        manufacturers: catalogPayload.facets.manufacturers,
        categories: catalogPayload.facets.categories,
        integrations: catalogPayload.facets.integrations,
        platforms: catalogPayload.facets.platforms,
        hubs: catalogPayload.facets.hubs,
        featureCounts,
      }}
      uiConfig={{ lockedFilters: { hubs: [hub.slug] } }}
    />
  </div>
</BaseLayout>
