---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readExportJson } from "../../lib/exports";

interface HubsExport {
  count: number;
}

const hubs = await readExportJson<HubsExport>("hubs.json");
---

<BaseLayout
  title="Hubs | SmartPicker"
  description="Temporary hubs landing page for the Astro foundation pass."
>
  <section class="panel mx-auto max-w-3xl p-8">
    <p
      class="text-brand-strong text-sm font-semibold tracking-[0.24em] uppercase"
    >
      Hubs
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight">
      Hub coverage placeholder
    </h1>
    <p class="text-muted mt-4 text-base leading-8">
      This route is here to validate navigation and shared styling while we
      build the real hub listing and detail templates. Current imported hubs: <span
        class="text-foreground font-semibold">{hubs.count}</span
      >.
    </p>
  </section>
</BaseLayout>
