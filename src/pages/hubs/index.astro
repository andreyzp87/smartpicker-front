---
import type {
  HubsResponse,
  ProductsIndexResponse,
} from "../../../data/exports/types";
import BaseLayout from "../../layouts/BaseLayout.astro";
import HubFeatureCard from "../../components/hubs/HubFeatureCard.astro";
import HubTableCell from "../../components/hubs/HubTableCell.astro";
import DataTableSection from "../../components/ui/DataTableSection.astro";
import PageIntro from "../../components/ui/PageIntro.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import { readExportJson } from "../../lib/exports";
import { formatProtocolLabel, getProtocolStyle } from "../../lib/ui";

const [hubs, products] = await Promise.all([
  readExportJson<HubsResponse>("hubs.json"),
  readExportJson<ProductsIndexResponse>("products.json"),
]);

const productsByHub = new Map<string, ProductsIndexResponse["products"]>();

for (const hub of hubs.hubs) {
  productsByHub.set(
    hub.slug,
    products.products.filter((product) =>
      product.compatibleHubSlugs.includes(hub.slug),
    ),
  );
}

const enrichedHubs = hubs.hubs
  .map((hub) => {
    const mappedProducts = productsByHub.get(hub.slug) ?? [];
    const protocolCounts = mappedProducts.reduce<Record<string, number>>(
      (counts, product) => {
        if (product.primaryProtocol) {
          counts[product.primaryProtocol] =
            (counts[product.primaryProtocol] ?? 0) + 1;
        }

        return counts;
      },
      {},
    );

    return {
      ...hub,
      protocolsSupported: Object.keys(protocolCounts),
      protocolCounts,
    };
  })
  .sort((left, right) =>
    right.compatibleDeviceCount === left.compatibleDeviceCount
      ? left.name.localeCompare(right.name)
      : right.compatibleDeviceCount - left.compatibleDeviceCount,
  );

const totalProtocols = new Set(
  enrichedHubs.flatMap((hub) => hub.protocolsSupported),
).size;
const totalStatusFamilies = new Set(
  enrichedHubs.flatMap((hub) => Object.keys(hub.statusBreakdown)),
).size;
const formatCount = new Intl.NumberFormat("en-US");
const hubColumns = [
  { key: "hub", label: "Hub" },
  { key: "protocols", label: "Protocols represented" },
  { key: "status", label: "Status coverage" },
  { key: "devices", label: "Devices", align: "right" as const },
  { key: "action", label: "", align: "right" as const },
];
---

<BaseLayout
  title="Commercial Hubs | SmartPicker"
  description="Compare commercial smart home hubs by compatible device coverage and current status breakdown."
>
  <div class="mx-auto max-w-[1200px] px-6">
    <PageIntro
      title="Commercial Hubs"
      description="Commercial hubs are kept separate from integrations and platforms. Use this page to compare ecosystem-specific hub products and their current compatible device coverage."
      stats={[
        { value: formatCount.format(hubs.count), label: "Hubs tracked" },
        {
          value: formatCount.format(totalProtocols),
          label: "Protocols represented",
        },
        { value: formatCount.format(products.count), label: "Devices indexed" },
        {
          value: formatCount.format(totalStatusFamilies),
          label: "Status buckets",
        },
      ]}
    />

    <div class="mb-6 flex flex-wrap gap-3">
      {
        ["zigbee", "zwave", "matter", "wifi", "thread", "bluetooth"].map(
          (slug) => (
            <span class="border-theme bg-surface text-secondary shadow-card inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-sm">
              <span
                class:list={[
                  "inline-flex h-2.5 w-2.5 rounded-full",
                  getProtocolStyle(slug).badge,
                ]}
              />
              {formatProtocolLabel(slug)}
            </span>
          ),
        )
      }
    </div>

    <SectionHeader
      eyebrow="Featured hubs"
      title="Commercial ecosystems worth comparing"
    />

    <section
      class="grid [grid-template-columns:repeat(auto-fit,minmax(320px,1fr))] gap-4 pb-6"
    >
      {
        enrichedHubs.map((hub, index) => (
          <div style={`animation-delay:${0.05 + index * 0.05}s`}>
            <HubFeatureCard
              href={`/hubs/${hub.slug}`}
              name={hub.name}
              manufacturerName={hub.manufacturer?.name ?? "Independent"}
              protocolsSupported={hub.protocolsSupported}
              verifiedCount={formatCount.format(
                hub.statusBreakdown.verified ?? 0,
              )}
              reportedCount={formatCount.format(
                hub.statusBreakdown.reported ?? 0,
              )}
              untestedCount={formatCount.format(
                hub.statusBreakdown.untested ?? 0,
              )}
              protocolCounts={Object.entries(hub.protocolCounts)
                .filter(([, count]) => count > 0)
                .sort((left, right) => right[1] - left[1])
                .map(([protocol, count]) => ({ protocol, count }))}
              deviceCount={hub.compatibleDeviceCount}
            />
          </div>
        ))
      }
    </section>

    <DataTableSection
      class="mb-0"
      title="All Commercial Hubs"
      summaryLabel={`${formatCount.format(hubs.count)} hubs tracked`}
      columns={hubColumns}
      rows={enrichedHubs}
      mobileMode="scroll"
      cellComponent={HubTableCell}
    />

    <section class="grid gap-4 pt-6 pb-20 md:grid-cols-2">
      <article
        class="border-theme bg-surface shadow-card rounded-2xl border p-6"
      >
        <h3
          class="mb-3 flex items-center gap-2 text-lg font-bold tracking-tight"
        >
          <span
            class="bg-elevated inline-flex h-7 w-7 items-center justify-center rounded-lg text-sm"
          >
            H
          </span>
          What counts as a hub here?
        </h3>
        <p class="text-secondary text-sm leading-relaxed">
          Hub pages are now explicitly about commercial hubs and ecosystems.
          Open platforms and integrations are tracked on their own routes.
        </p>
      </article>
      <article
        class="border-theme bg-surface shadow-card rounded-2xl border p-6"
      >
        <h3
          class="mb-3 flex items-center gap-2 text-lg font-bold tracking-tight"
        >
          <span
            class="bg-elevated inline-flex h-7 w-7 items-center justify-center rounded-lg text-sm"
          >
            ↔
          </span>
          Why separate them?
        </h3>
        <p class="text-secondary text-sm leading-relaxed">
          A commercial hub is one compatibility target, but it is not the same
          thing as an integration or an automation platform. SmartPicker keeps
          those layers distinct so support is easier to interpret.
        </p>
      </article>
    </section>
  </div>
</BaseLayout>
