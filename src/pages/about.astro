---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About SmartPicker"
  description="Early SmartPicker Astro implementation notes and testing page."
>
  <section class="panel mx-auto max-w-3xl p-8">
    <p
      class="text-brand-strong text-sm font-semibold tracking-[0.24em] uppercase"
    >
      About
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight">
      Public site foundation
    </h1>
    <p class="text-muted mt-4 text-base leading-8">
      This placeholder page exists so the shared site shell can be tested
      end-to-end while the full information architecture is still being built.
      It confirms shared layout, metadata, and Tailwind styling across multiple
      routes.
    </p>
  </section>
</BaseLayout>
