---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ui/ButtonLink.astro";
import PageIntro from "../components/ui/PageIntro.astro";
import SectionHeader from "../components/ui/SectionHeader.astro";
import StatGrid from "../components/ui/StatGrid.astro";
import { readExportJson } from "../lib/exports";
import { formatProtocolLabel } from "../lib/ui";

interface SiteExport {
  generated: string;
  stats: {
    devices: number;
    hubs: number;
    manufacturers: number;
    categories: number;
    protocols: number;
  };
  protocolCounts: Record<string, number>;
}

interface SitemapExport {
  count: number;
  urls: {
    path: string;
    type: string;
    lastModified: string;
  }[];
}

const site = await readExportJson<SiteExport>("site.json");
const sitemap = await readExportJson<SitemapExport>("sitemap.json");

const formatCount = new Intl.NumberFormat("en-US");
const generatedLabel = new Date(site.generated).toLocaleString("en-US", {
  dateStyle: "medium",
  timeStyle: "short",
});
const activeProtocolEntries = Object.entries(site.protocolCounts).filter(
  ([, count]) => count > 0,
);
const activeProtocolLabel =
  activeProtocolEntries.length > 0
    ? activeProtocolEntries
        .map(([slug]) => formatProtocolLabel(slug))
        .join(", ")
    : "No mapped protocols yet";

const dataSources = [
  {
    iconClass: "bg-zigbee text-zigbee",
    icon: "Z2M",
    name: "Zigbee2MQTT",
    description:
      "Provides detailed Zigbee device definitions that help verify model names, compatibility metadata, and product-level coverage.",
    detail: "Reference source for Zigbee device support.",
  },
  {
    iconClass: "bg-zigbee text-zigbee",
    icon: "BL",
    name: "Blakadder",
    description:
      "Supports cross-platform compatibility research with useful community context around integrations, controllers, and device support.",
    detail: "Reference source for ecosystem coverage.",
  },
  {
    iconClass: "bg-zwave text-zwave",
    icon: "ZW",
    name: "Z-Wave JS",
    description:
      "Helps anchor Z-Wave product identification and ecosystem information for devices, hubs, and future compatibility coverage.",
    detail: "Reference source for Z-Wave metadata.",
  },
];
---

<BaseLayout
  title="About SmartPicker"
  description="Learn how SmartPicker helps you evaluate smart home compatibility with clearer device, hub, manufacturer, and protocol information."
>
  <div class="mx-auto max-w-[1200px] px-6">
    <PageIntro
      title="A clearer way to evaluate smart home compatibility"
      description="SmartPicker helps you compare devices, hubs, manufacturers, and wireless standards before you buy, so you can build a setup that fits your home and your expectations."
      descriptionClass="max-w-[680px] text-lg"
    >
      <p class="mt-4 max-w-[760px] text-sm leading-relaxed text-muted">
        Catalog data was last refreshed {generatedLabel}.
      </p>
    </PageIntro>

    <div class="my-8">
      <StatGrid
        align="center"
        columnsClass="grid-cols-4 max-md:grid-cols-2"
        items={[
          { value: formatCount.format(site.stats.devices), label: "Devices" },
          { value: formatCount.format(site.stats.manufacturers), label: "Manufacturers" },
          { value: formatCount.format(site.stats.protocols), label: "Protocols" },
          { value: formatCount.format(sitemap.count), label: "Catalog pages" },
        ]}
      />
    </div>

    <section class="animate-fade-in">
      <SectionHeader class="mt-12" title="Why SmartPicker" />
      <p class="mb-4 text-base leading-relaxed text-secondary">
        Building a smart home often means comparing product pages, integration
        lists, and community discussions just to answer a simple question: will
        this device work with the rest of my setup?
      </p>
      <p class="text-base leading-relaxed text-secondary">
        SmartPicker brings those decisions into one place. The goal is to make
        compatibility easier to understand, easier to compare, and easier to
        trust when you are choosing devices, hubs, or an entire ecosystem.
      </p>
    </section>

    <div class="my-7 mb-10 grid grid-cols-3 gap-3 max-md:grid-cols-1">
      <div class="rounded-2xl border border-theme bg-surface px-5 py-6">
        <div class="mb-3.5 flex h-7 w-7 items-center justify-center rounded-full border border-blue bg-blue-subtle font-mono text-[13px] font-bold text-blue">
          1
        </div>
        <div class="mb-1.5 text-[15px] font-bold">Compare devices</div>
        <div class="text-[13px] leading-relaxed text-secondary">
          Review protocol support, hub compatibility, and key product traits in
          one place instead of stitching details together from multiple tabs.
        </div>
      </div>
      <div class="rounded-2xl border border-theme bg-surface px-5 py-6">
        <div class="mb-3.5 flex h-7 w-7 items-center justify-center rounded-full border border-blue bg-blue-subtle font-mono text-[13px] font-bold text-blue">
          2
        </div>
        <div class="mb-1.5 text-[15px] font-bold">Understand protocols</div>
        <div class="text-[13px] leading-relaxed text-secondary">
          See which standards are widely supported, which brands use them, and
          which hubs are most relevant for your preferred ecosystem.
        </div>
      </div>
      <div class="rounded-2xl border border-theme bg-surface px-5 py-6">
        <div class="mb-3.5 flex h-7 w-7 items-center justify-center rounded-full border border-blue bg-blue-subtle font-mono text-[13px] font-bold text-blue">
          3
        </div>
        <div class="mb-1.5 text-[15px] font-bold">Choose with confidence</div>
        <div class="text-[13px] leading-relaxed text-secondary">
          SmartPicker is designed to show coverage clearly, so you can make
          better decisions about reliability, local control, and platform fit.
        </div>
      </div>
    </div>

    <section class="animate-fade-in">
      <SectionHeader class="mt-12" title="Data sources" />
      <p class="mb-4 text-base leading-relaxed text-secondary">
        SmartPicker is informed by established smart home data sources and
        community knowledge from the ecosystems people already rely on.
      </p>
    </section>

    <div class="my-7 mb-10 grid grid-cols-1 gap-3">
      {
        dataSources.map((source, index) => (
          <article
            class="flex items-center gap-[18px] rounded-2xl border border-theme bg-surface px-6 py-5 transition-colors hover:border-theme-hover"
            style={`animation-delay:${0.3 + index * 0.05}s`}
          >
            <div
              class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-xl text-sm font-bold ${source.iconClass}`}
            >
              {source.icon}
            </div>
            <div class="min-w-0 flex-1">
              <div class="mb-0.5 text-[15px] font-bold">{source.name}</div>
              <div class="text-[13px] leading-relaxed text-secondary">
                {source.description}
              </div>
              <div class="mt-1 text-xs font-mono text-muted">{source.detail}</div>
            </div>
          </article>
        ))
      }
    </div>

    <blockquote class="my-6 rounded-r-[10px] border-l-[3px] border-[var(--sp-blue-400)] bg-blockquote px-6 py-5">
      <p class="text-base leading-relaxed text-secondary">
        SmartPicker would rather show limited coverage clearly than overstate
        support. Today, active device coverage is strongest in {activeProtocolLabel}.
      </p>
    </blockquote>

    <section class="animate-fade-in">
      <SectionHeader class="mt-12" title="What you can expect" />
    </section>

    <div class="my-7 mb-10 grid grid-cols-2 gap-3 max-md:grid-cols-1">
      <article class="rounded-2xl border border-theme bg-surface p-6">
        <h3 class="mb-2 flex items-center gap-2 text-lg font-bold tracking-tight">
          <span class="inline-flex h-6 w-6 items-center justify-center rounded-md border border-green bg-green-subtle text-[13px] text-green">
            ✓
          </span>
          Clear coverage
        </h3>
        <p class="text-base leading-relaxed text-secondary">
          Device, hub, and protocol pages are designed to make support levels
          easy to scan, compare, and understand quickly.
        </p>
      </article>
      <article class="rounded-2xl border border-theme bg-surface p-6">
        <h3 class="mb-2 flex items-center gap-2 text-lg font-bold tracking-tight">
          <span class="inline-flex h-6 w-6 items-center justify-center rounded-md border border-amber bg-amber-subtle text-[13px] text-amber">
            ⚡
          </span>
          Local-first thinking
        </h3>
        <p class="text-base leading-relaxed text-secondary">
          Local control and hub requirements matter because long-term reliability
          matters. SmartPicker keeps those signals visible during comparison.
        </p>
      </article>
      <article class="rounded-2xl border border-theme bg-surface p-6">
        <h3 class="mb-2 flex items-center gap-2 text-lg font-bold tracking-tight">
          <span class="inline-flex h-6 w-6 items-center justify-center rounded-md border border-purple bg-purple-subtle text-[13px] text-purple">
            ↗
          </span>
          Practical organization
        </h3>
        <p class="text-base leading-relaxed text-secondary">
          Browse by product, brand, hub, or protocol depending on how you shop
          and how you think about your smart home.
        </p>
      </article>
      <article class="rounded-2xl border border-theme bg-surface p-6">
        <h3 class="mb-2 flex items-center gap-2 text-lg font-bold tracking-tight">
          <span class="inline-flex h-6 w-6 items-center justify-center rounded-md border border-cyan bg-cyan-subtle text-[13px] text-cyan">
            ⌁
          </span>
          Fast comparison
        </h3>
        <p class="text-base leading-relaxed text-secondary">
          The site is built to reduce research time when you are comparing
          several devices, platforms, or manufacturers at once.
        </p>
      </article>
    </div>

    <section class="animate-fade-in">
      <SectionHeader class="mt-12" title="Current coverage" />
      <p class="text-base leading-relaxed text-secondary">
        SmartPicker currently covers {formatCount.format(site.stats.devices)}
        devices across {formatCount.format(site.stats.manufacturers)}
        {" "}manufacturers and {formatCount.format(site.stats.protocols)} protocol
        families, with {formatCount.format(sitemap.count)} pages available for
        browsing and comparison.
      </p>
    </section>

    <div class="my-7 mb-12 grid grid-cols-3 gap-3 max-md:grid-cols-1">
      <article class="rounded-2xl border border-theme bg-surface p-6">
        <h3 class="text-base font-bold tracking-tight">Devices</h3>
        <p class="mt-2 text-sm leading-relaxed text-secondary">
          Review product pages for protocol, control method, hub compatibility,
          and model-level detail.
        </p>
      </article>
      <article class="rounded-2xl border border-theme bg-surface p-6">
        <h3 class="text-base font-bold tracking-tight">Hubs and platforms</h3>
        <p class="mt-2 text-sm leading-relaxed text-secondary">
          Compare controllers by supported protocols, connected devices, and
          overall coverage across the catalog.
        </p>
      </article>
      <article class="rounded-2xl border border-theme bg-surface p-6">
        <h3 class="text-base font-bold tracking-tight">Brands and protocols</h3>
        <p class="mt-2 text-sm leading-relaxed text-secondary">
          Understand how manufacturers and wireless standards fit into the
          broader smart home landscape before committing to a direction.
        </p>
      </article>
    </div>

    <div class="my-12 rounded-2xl border border-theme bg-hero-gradient px-8 py-9 text-center">
      <h2 class="text-[22px] font-bold tracking-tight">Start exploring</h2>
      <p class="mx-auto mt-3 max-w-[760px] text-base leading-relaxed text-secondary">
        Whether you are evaluating a single device or narrowing down an entire
        platform, SmartPicker gives you a faster path to the details that matter.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <ButtonLink href="/devices">
          Browse devices
        </ButtonLink>
        <ButtonLink href="/protocols" variant="secondary">
          Explore protocols
        </ButtonLink>
      </div>
    </div>

    <section class="animate-fade-in pb-16">
      <SectionHeader class="mt-12" title="Who SmartPicker is for" />
      <p class="text-base leading-relaxed text-secondary">
        SmartPicker is useful for homeowners, installers, and enthusiasts who
        want to make better buying decisions with less guesswork.
      </p>
      <p class="mt-4 text-base leading-relaxed text-secondary">
        If you care about compatibility, local control, or long-term platform
        flexibility, the catalog is designed to help you compare options without
        digging through scattered sources first.
      </p>
    </section>
  </div>
</BaseLayout>
