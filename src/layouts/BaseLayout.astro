---
import BrandMark from "../components/layout/BrandMark.astro";
import FooterLinkColumn from "../components/layout/FooterLinkColumn.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SmartPicker",
  description = "Smart home device compatibility across integrations, platforms, and commercial hubs in one searchable catalog.",
} = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/devices", label: "Devices" },
  { href: "/integrations", label: "Integrations" },
  { href: "/platforms", label: "Platforms" },
  { href: "/hubs", label: "Hubs" },
  { href: "/protocols", label: "Protocols" },
  { href: "/manufacturers", label: "Manufacturers" },
  { href: "/categories", label: "Categories" },
  { href: "/about", label: "About" },
];
const footerBrowseLinks = [
  { href: "/", label: "Home" },
  { href: "/devices", label: "All Devices" },
  { href: "/integrations", label: "Integrations" },
  { href: "/platforms", label: "Platforms" },
  { href: "/hubs", label: "Hubs" },
  { href: "/protocols", label: "Protocols" },
  { href: "/manufacturers", label: "Manufacturers" },
  { href: "/categories", label: "Categories" },
];
const footerProjectLinks = [
  { href: "/about", label: "About" },
  { href: "/about", label: "Data Sources" },
];

function isActivePath(path: string): boolean {
  return path === "/" ? pathname === "/" : pathname === path || pathname.startsWith(`${path}/`);
}

function navLinkClass(path: string): string {
  const isActive = isActivePath(path);

  return [
    "rounded-md px-3.5 py-1.5 text-sm font-medium transition-all",
    isActive
      ? "bg-blue-subtle text-blue"
      : "text-secondary hover:bg-hover hover:text-primary",
  ].join(" ");
}
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      (() => {
        const storageKey = "smartpicker-theme";
        const storedTheme = window.localStorage.getItem(storageKey);
        const theme =
          storedTheme === "dark" || storedTheme === "light"
            ? storedTheme
            : "light";

        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body class="bg-body text-primary">
    <div class="relative min-h-screen overflow-hidden">
      <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-[32rem] bg-[radial-gradient(circle_at_top,_var(--sp-blue-glow)_0%,transparent_68%)]">
        </div>
      </div>

      <header class="sticky top-0 z-50 border-b border-theme bg-header backdrop-blur-[20px]">
        <div class="mx-auto flex h-16 max-w-[1200px] items-center justify-between px-6">
          <BrandMark />

          <div class="flex items-center gap-2">
            <nav class="hidden items-center gap-1 md:flex">
              {
                navItems.map((item) => (
                  <a
                    href={item.href}
                    class={navLinkClass(item.href)}
                    aria-current={isActivePath(item.href) ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                ))
              }
            </nav>

            <button
              type="button"
              data-mobile-menu-toggle
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[10px] border border-theme bg-hover text-secondary transition-all hover:border-theme-hover hover:text-primary md:hidden"
              title="Open navigation"
              aria-label="Open navigation"
              aria-expanded="false"
              aria-controls="mobile-navigation"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 6h18M3 12h18M3 18h18"></path>
              </svg>
            </button>

            <button
              type="button"
              data-theme-toggle
              class="ml-2 flex h-10 w-10 shrink-0 items-center justify-center rounded-[10px] border border-theme bg-hover text-secondary transition-all hover:border-theme-hover hover:text-primary max-md:ml-0"
              title="Toggle theme"
              aria-label="Toggle theme"
            >
              <svg
                class="theme-icon-sun"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="5"></circle>
                <path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42">
                </path>
              </svg>
              <svg
                class="theme-icon-moon"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            </button>
          </div>
        </div>

        <div
          id="mobile-navigation"
          data-mobile-menu
          hidden
          class="border-t border-theme px-6 py-4 md:hidden"
        >
          <nav class="mx-auto flex max-w-[1200px] flex-col gap-2">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class={navLinkClass(item.href)}
                  data-mobile-nav-link
                  aria-current={isActivePath(item.href) ? "page" : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="mt-20 border-t border-theme px-6 py-10">
        <div class="mx-auto flex max-w-[1200px] items-start justify-between gap-8 max-md:flex-col">
          <div class="flex max-w-[320px] flex-col gap-2">
            <BrandMark />
            <p class="text-[13px] leading-relaxed text-muted">
              The smart home compatibility database for finding devices that fit
              your stack before you buy.
            </p>
          </div>

          <div class="flex gap-12 max-md:gap-8 max-sm:flex-col">
            <FooterLinkColumn title="Browse" links={footerBrowseLinks} />
            <FooterLinkColumn title="Project" links={footerProjectLinks} />
          </div>
        </div>

        <div class="mx-auto mt-6 flex max-w-[1200px] items-center justify-between gap-4 border-t border-theme pt-6 max-md:flex-col max-md:items-start">
          <p class="text-xs text-muted">
            © 2026 SmartPicker. Data from open-source projects and community
            exports.
          </p>
          <p class="text-xs text-muted">Built with Astro and Tailwind CSS.</p>
        </div>
      </footer>
    </div>

    <script is:inline>
      (() => {
        const storageKey = "smartpicker-theme";
        const button = document.querySelector("[data-theme-toggle]");
        const mobileMenuToggle = document.querySelector("[data-mobile-menu-toggle]");
        const mobileMenu = document.querySelector("[data-mobile-menu]");

        if (!button) {
          return;
        }

        button.addEventListener("click", () => {
          const html = document.documentElement;
          const currentTheme = html.getAttribute("data-theme");
          const nextTheme = currentTheme === "dark" ? "light" : "dark";

          html.setAttribute("data-theme", nextTheme);
          window.localStorage.setItem(storageKey, nextTheme);
        });

        if (mobileMenuToggle instanceof HTMLButtonElement && mobileMenu instanceof HTMLElement) {
          const syncMenuButton = (isOpen) => {
            mobileMenuToggle.setAttribute("aria-expanded", String(isOpen));
            mobileMenuToggle.setAttribute("aria-label", isOpen ? "Close navigation" : "Open navigation");
            mobileMenuToggle.setAttribute("title", isOpen ? "Close navigation" : "Open navigation");
          };

          const closeMenu = () => {
            mobileMenu.hidden = true;
            syncMenuButton(false);
          };

          mobileMenuToggle.addEventListener("click", () => {
            const isOpen = mobileMenu.hidden === false;
            mobileMenu.hidden = isOpen;
            syncMenuButton(!isOpen);
          });

          mobileMenu.querySelectorAll("[data-mobile-nav-link]").forEach((link) => {
            link.addEventListener("click", closeMenu);
          });

          window.addEventListener("resize", () => {
            if (window.innerWidth >= 768) {
              closeMenu();
            }
          });

          syncMenuButton(false);
        }
      })();
    </script>
  </body>
</html>
