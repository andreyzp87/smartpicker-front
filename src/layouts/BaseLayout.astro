---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SmartPicker",
  description = "Smart home device compatibility, protocols, and hub support in one searchable catalog.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="relative isolate overflow-hidden">
      <div
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[34rem] bg-[radial-gradient(circle_at_top,_oklch(0.86_0.1_195_/_0.32),_transparent_60%)]"
      >
      </div>
      <header
        class="mx-auto flex max-w-7xl items-center justify-between px-6 py-6 lg:px-8"
      >
        <a
          href="/"
          class="text-brand-strong flex items-center gap-3 text-sm font-semibold tracking-[0.24em] uppercase"
        >
          <span
            class="bg-brand shadow-brand/30 flex size-10 items-center justify-center rounded-2xl text-white shadow-lg"
            >SP</span
          >
          SmartPicker
        </a>
        <nav class="text-muted hidden items-center gap-6 text-sm md:flex">
          <a href="/" class="text-foreground hover:text-brand-strong">Home</a>
          <a href="/devices" class="hover:text-brand-strong">Devices</a>
          <a href="/hubs" class="hover:text-brand-strong">Hubs</a>
          <a href="/about" class="hover:text-brand-strong">About</a>
        </nav>
      </header>

      <main class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
        <slot />
      </main>

      <footer
        class="text-muted mx-auto flex max-w-7xl flex-col gap-3 border-t border-white/50 px-6 py-8 text-sm lg:flex-row lg:items-center lg:justify-between lg:px-8"
      >
        <p>
          Smart home compatibility research, rendered with Astro and Tailwind.
        </p>
        <p>Foundation slice for the new public site.</p>
      </footer>
    </div>
  </body>
</html>
