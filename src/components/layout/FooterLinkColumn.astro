---
interface LinkItem {
  href: string;
  label: string;
}

interface Props {
  title: string;
  links: LinkItem[];
}

const { title, links } = Astro.props;
---

<div>
  <h4 class="mb-3 text-[13px] font-semibold uppercase tracking-wider text-secondary">
    {title}
  </h4>
  <ul class="space-y-0.5">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="block py-0.5 text-sm text-muted transition-colors hover:text-secondary"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</div>
