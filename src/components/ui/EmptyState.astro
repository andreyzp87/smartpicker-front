---
import ButtonLink from "./ButtonLink.astro";

interface Action {
  href: string;
  label: string;
  variant?: "primary" | "secondary" | "subtle";
}

interface Props {
  title: string;
  description: string;
  icon?: string;
  primaryAction?: Action;
  secondaryAction?: Action;
}

const {
  title,
  description,
  icon = "•",
  primaryAction,
  secondaryAction,
} = Astro.props;
---

<section class="rounded-2xl border border-theme bg-surface p-6 shadow-card">
  <div class="flex items-start gap-4">
    <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl border border-theme bg-elevated text-xl font-bold text-secondary">
      {icon}
    </div>
    <div class="min-w-0 flex-1">
      <h3 class="text-2xl font-semibold tracking-tight">{title}</h3>
      <p class="mt-3 max-w-[760px] text-sm leading-relaxed text-muted">
        {description}
      </p>
      <slot />
      {
        (primaryAction || secondaryAction) && (
          <div class="mt-5 flex flex-wrap gap-3">
            {
              primaryAction && (
                <ButtonLink
                  href={primaryAction.href}
                  variant={primaryAction.variant ?? "primary"}
                >
                  {primaryAction.label}
                </ButtonLink>
              )
            }
            {
              secondaryAction && (
                <ButtonLink
                  href={secondaryAction.href}
                  variant={secondaryAction.variant ?? "secondary"}
                >
                  {secondaryAction.label}
                </ButtonLink>
              )
            }
          </div>
        )
      }
    </div>
  </div>
</section>
