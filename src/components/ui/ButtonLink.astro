---
import { joinClasses } from "../../lib/ui";

interface Props {
  href: string;
  variant?: "primary" | "secondary" | "link" | "subtle";
  class?: string;
}

const { href, variant = "primary", class: className } = Astro.props;

const isLinkVariant = variant === "link" || variant === "subtle";
const baseClass = isLinkVariant
  ? "inline-flex items-center gap-2 text-sm font-semibold transition-all"
  : "inline-flex items-center gap-2 rounded-[10px] px-6 py-3 text-sm font-semibold transition-all";
const variantClass =
  variant === "primary"
    ? "bg-blue-gradient text-white hover:brightness-110 hover:shadow-blue-lg"
    : variant === "secondary"
      ? "border border-theme-hover bg-hover text-secondary hover:bg-badge hover:text-primary"
      : "text-blue hover:text-primary";
---

<a href={href} class={joinClasses(baseClass, variantClass, className)}>
  <slot />
</a>
