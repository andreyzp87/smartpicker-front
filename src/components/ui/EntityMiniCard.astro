---
interface Props {
  href?: string;
  title: string;
  meta?: string | null;
}

const { href, title, meta } = Astro.props;
const Tag = href ? "a" : "article";
---

<Tag
  href={href}
  class="card-hover border-theme bg-surface text-primary flex flex-col gap-1.5 rounded-2xl border p-5"
>
  <div class="text-base font-semibold">{title}</div>
  {meta && <div class="text-muted text-[13px] leading-relaxed">{meta}</div>}
</Tag>
