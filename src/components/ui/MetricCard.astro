---
interface Props {
  value: string | number;
  label: string;
  description?: string;
  tone?: "default" | "accent";
  class?: string;
}

const {
  value,
  label,
  description,
  tone = "default",
  class: className,
} = Astro.props;
---

<div class:list={["border-theme bg-surface rounded-2xl border p-5", className]}>
  <div
    class:list={[
      "tabular-nums text-[28px] font-bold tracking-tight",
      tone === "accent" ? "text-gradient" : "text-primary",
    ]}
  >
    {value}
  </div>
  <div
    class="text-muted mt-1 text-[11px] font-semibold tracking-wider uppercase"
  >
    {label}
  </div>
  {
    description && (
      <p class="text-secondary mt-2 text-sm leading-relaxed">{description}</p>
    )
  }
</div>
