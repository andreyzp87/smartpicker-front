---
import { joinClasses } from "../../lib/ui";
import StatGrid from "./StatGrid.astro";

interface BadgeItem {
  label: string;
  href?: string;
  class?: string;
}

interface StatItem {
  value: string;
  label: string;
  muted?: boolean;
}

interface Props {
  icon?: string;
  title: string;
  description: string;
  badges?: BadgeItem[];
  stats?: StatItem[];
  pretitle?: string;
  layout?: "standard" | "media-left";
  class?: string;
  iconClass?: string;
  statsColumnsClass?: string;
  statsWrapperClass?: string;
  statsAlign?: "left" | "center";
}

const {
  icon,
  title,
  description,
  badges = [],
  stats = [],
  pretitle,
  layout = "standard",
  class: className,
  iconClass,
  statsColumnsClass,
  statsWrapperClass,
  statsAlign = "left",
} = Astro.props;

const hasIconSlot = Astro.slots.has("icon");
const hasPretitleSlot = Astro.slots.has("pretitle");
const hasBadgesSlot = Astro.slots.has("badges");
const showIcon = hasIconSlot || Boolean(icon);
const showBadges = hasBadgesSlot || badges.length > 0;
const showStats = stats.length > 0;
const sectionClass =
  layout === "media-left"
    ? "grid grid-cols-[280px_1fr] gap-8 py-6 pb-10 max-md:grid-cols-1"
    : "flex items-start gap-6 py-8 pb-10 max-md:flex-col";
const iconBaseClass =
  layout === "media-left"
    ? hasIconSlot
      ? "min-w-0"
      : "border-theme bg-surface text-muted relative flex aspect-square items-center justify-center overflow-hidden rounded-2xl border text-[72px]"
    : hasIconSlot
      ? "shrink-0"
      : "bg-elevated text-secondary flex h-20 w-20 shrink-0 items-center justify-center rounded-[28px] text-2xl font-bold tracking-[-0.05em]";
const contentClass = layout === "media-left" ? "min-w-0" : "min-w-0 flex-1";
---

<section class:list={[sectionClass, className]}>
  {showIcon && (
    <div class:list={[iconBaseClass, iconClass]}>
      {
        hasIconSlot ? (
          <slot name="icon" />
        ) : layout === "media-left" ? (
          <span class="font-semibold tracking-[-0.08em]">{icon}</span>
        ) : (
          icon
        )
      }
    </div>
  )}

  <div class:list={[contentClass]}>
    {(hasPretitleSlot || pretitle) && (
      <div class="text-muted mb-2 text-[13px] font-semibold tracking-wider uppercase">
        {hasPretitleSlot ? <slot name="pretitle" /> : pretitle}
      </div>
    )}

    <h1 class="text-[clamp(34px,4vw,48px)] leading-[1.05] font-bold tracking-[-0.035em]">
      {title}
    </h1>
    <p class="text-secondary mt-3 max-w-[860px] text-base leading-relaxed">
      {description}
    </p>

    {showBadges && (
      <div class="mt-4 flex flex-wrap gap-2">
        {badges.map((badge) =>
          badge.href ? (
            <a
              href={badge.href}
              class={joinClasses(
                "border-theme bg-badge text-secondary rounded-md border px-3 py-1 text-[13px] font-medium",
                badge.class,
              )}
            >
              {badge.label}
            </a>
          ) : (
            <span
              class={joinClasses(
                "border-theme bg-badge text-secondary rounded-md border px-3 py-1 text-[13px] font-medium",
                badge.class,
              )}
            >
              {badge.label}
            </span>
          ),
        )}
        <slot name="badges" />
      </div>
    )}

    {showStats && (
      <div class:list={["mt-6", statsWrapperClass]}>
        <StatGrid
          items={stats}
          columnsClass={statsColumnsClass}
          align={statsAlign}
        />
      </div>
    )}
  </div>
</section>
