---
interface Props {
  title: string;
  compact?: boolean;
  class?: string;
}

const { title, compact = false, class: className } = Astro.props;
---

<section
  class:list={[
    "rounded-2xl border border-theme bg-surface shadow-card",
    className,
  ]}
>
  <div class="border-b border-theme px-5 py-4 text-lg font-semibold tracking-tight">
    {title}
  </div>
  <div class:list={["px-5 py-4", compact && "px-4 py-3"]}>
    <slot />
  </div>
</section>
