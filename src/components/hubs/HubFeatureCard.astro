---
import { formatProtocolLabel, getProtocolStyle, joinClasses } from "../../lib/ui";

interface HubProtocolCount {
  protocol: string;
  count: number;
}

interface Props {
  href: string;
  name: string;
  manufacturerName: string;
  protocolsSupported: string[];
  verifiedCount: string;
  reportedCount: string;
  untestedCount: string;
  protocolCounts: HubProtocolCount[];
  deviceCount: number;
}

const {
  href,
  name,
  manufacturerName,
  protocolsSupported,
  verifiedCount,
  reportedCount,
  untestedCount,
  protocolCounts,
  deviceCount,
} = Astro.props;
---

<a
  href={href}
  class="flex flex-col rounded-2xl border border-theme bg-surface text-primary shadow-card transition-all hover:-translate-y-0.5 hover:border-theme-hover"
>
  <div class="flex items-center gap-4 px-6 pt-6">
    <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-elevated text-lg font-semibold text-secondary">
      H
    </div>
    <div class="min-w-0 flex-1">
      <div class="mb-0.5 text-lg font-bold tracking-tight">{name}</div>
      <div class="text-[13px] text-muted">{manufacturerName}</div>
    </div>
  </div>

  <div class="flex flex-wrap gap-1.5 px-6 py-3">
    {
      protocolsSupported.map((protocol) => {
        const style = getProtocolStyle(protocol);

        return (
          <span
            class={joinClasses(
              "inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-[11px] font-semibold",
              style.badge,
              style.text,
            )}
          >
            {formatProtocolLabel(protocol)}
          </span>
        );
      })
    }
  </div>

  <div class="flex gap-6 px-6 py-4">
    <div class="flex flex-col gap-0.5">
      <span class="text-lg font-bold tabular-nums tracking-tight text-primary">
        {verifiedCount}
      </span>
      <span class="text-[11px] tracking-wider uppercase text-muted">Verified</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <span class="text-lg font-bold tabular-nums tracking-tight text-primary">
        {reportedCount}
      </span>
      <span class="text-[11px] tracking-wider uppercase text-muted">Reported</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <span class="text-lg font-bold tabular-nums tracking-tight text-muted">
        {untestedCount}
      </span>
      <span class="text-[11px] tracking-wider uppercase text-muted">Untested</span>
    </div>
  </div>

  <div class="mt-3 flex flex-col gap-2 border-t border-theme px-6 py-3.5">
    {
      protocolCounts.map(({ protocol, count }) => {
        const style = getProtocolStyle(protocol);
        const width = deviceCount > 0 ? Math.max((count / deviceCount) * 100, 8) : 0;

        return (
          <div class="grid grid-cols-[110px_1fr_auto] items-center gap-3">
            <span class="text-[13px] font-medium text-secondary">
              {formatProtocolLabel(protocol)}
            </span>
            <div class="h-2 overflow-hidden rounded-full bg-[var(--sp-bar-track)]">
              <div
                class={joinClasses("h-full rounded-full", style.badge)}
                style={`width:${width}%`}
              >
              </div>
            </div>
            <span class="tabular-nums text-[13px] text-secondary">{count}</span>
          </div>
        );
      })
    }
  </div>
</a>
