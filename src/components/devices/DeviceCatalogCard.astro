---
import CompatibilityBadge from "../ui/CompatibilityBadge.astro";
import ProtocolBadge from "../ui/ProtocolBadge.astro";
import { getProtocolStyle } from "../../lib/ui";

interface Props {
  href: string;
  name: string;
  manufacturerName: string;
  model?: string | null;
  protocolSlug?: string | null;
  compatibilityStatus?: string | null;
  categoryName?: string | null;
  hubCount: number;
}

const {
  href,
  name,
  manufacturerName,
  model,
  protocolSlug,
  compatibilityStatus,
  categoryName,
  hubCount,
} = Astro.props;
const style = getProtocolStyle(protocolSlug);
---

<a
  href={href}
  class="card-hover flex flex-col rounded-2xl border border-theme bg-surface p-5 text-primary"
>
  <div class="mb-3.5 flex items-start justify-between gap-3">
    <div class="flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-[10px] bg-elevated text-sm font-semibold text-muted">
      {style.shortLabel}
    </div>
    <ProtocolBadge
      slug={protocolSlug ?? null}
      class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide"
    />
  </div>
  <div class="mb-0.5 text-[15px] leading-tight font-semibold">{name}</div>
  <div class="mb-3 text-[13px] text-muted">
    {manufacturerName} · {model ?? "Model TBD"}
  </div>
  <div class="mt-auto flex flex-wrap gap-1.5">
    <CompatibilityBadge status={compatibilityStatus} fallbackLabel="Reported" class="px-2 py-0.5 text-[11px] font-medium" />
    {
      categoryName && (
        <span class="rounded-md border border-badge bg-badge px-2 py-0.5 text-[11px] font-medium text-secondary">
          {categoryName}
        </span>
      )
    }
  </div>
  <div class="mt-2.5 flex items-center gap-1 border-t border-theme pt-2.5">
    <span class="flex h-[18px] w-[18px] items-center justify-center rounded-full bg-green-subtle text-[9px] font-bold text-green">
      ✓
    </span>
    <span class="flex h-[18px] w-[18px] items-center justify-center rounded-full bg-green-subtle text-[9px] font-bold text-green">
      {hubCount}
    </span>
    <span class="ml-auto text-[11px] text-muted">
      {hubCount} hub{hubCount === 1 ? "" : "s"}
    </span>
  </div>
</a>
