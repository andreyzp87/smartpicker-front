---
interface Props {
  row: [string, number];
  column: {
    key: string;
  };
  total: number;
}

const {
  row: [category, count],
  column,
  total,
} = Astro.props;
const percentage = (count / Math.max(total, 1)) * 100;
---

{
  column.key === "category" ? (
    <div class="flex items-center gap-3">
      <div class="bg-elevated flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-base">
        {category === "Uncategorized" ? "?" : "■"}
      </div>
      <span class="text-sm font-medium">{category}</span>
    </div>
  ) : column.key === "share" ? (
    <div class="bg-bar-track h-2 overflow-hidden rounded-sm">
      <div
        class="bg-blue-gradient h-full rounded-sm"
        style={`width:${percentage}%`}
      />
    </div>
  ) : (
    <span class="text-secondary tabular-nums text-sm">
      {count.toLocaleString("en-US")}
    </span>
  )
}
