---
import { getProtocolStyle, joinClasses } from "../../lib/ui";

interface Props {
  href: string;
  slug: string;
  name: string;
  description: string;
  deviceCount: string;
  integrationCount: string;
  platformCount: string;
  hubCount: string;
  deviceShare: number;
}

const {
  href,
  slug,
  name,
  description,
  deviceCount,
  integrationCount,
  platformCount,
  hubCount,
  deviceShare,
} = Astro.props;

const style = getProtocolStyle(slug);
---

<a
  href={href}
  class="flex flex-col gap-4 rounded-2xl border border-theme bg-surface p-5 text-primary shadow-card transition-all hover:-translate-y-0.5 hover:border-theme-hover"
>
  <div class="flex items-start gap-4">
    <div
      class={joinClasses(
        "flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl text-sm font-bold tracking-[-0.04em]",
        style.badge,
        style.text,
      )}
    >
      {style.shortLabel}
    </div>
    <div class="min-w-0 flex-1">
      <div class="text-lg font-bold tracking-tight">{name}</div>
      <div class="mt-1 font-mono text-[13px] text-muted">{deviceCount} devices</div>
    </div>
  </div>

  <p class="text-sm leading-relaxed text-secondary">{description}</p>

  <div class="h-2 overflow-hidden rounded-full bg-[var(--sp-bar-track)]">
    <div
      class={joinClasses("h-full rounded-full", style.badge)}
      style={`width:${deviceShare}%`}
    >
    </div>
  </div>

  <div class="grid grid-cols-3 gap-3">
    <div class="flex flex-col gap-0.5">
      <span class="font-mono text-base font-bold text-primary">{integrationCount}</span>
      <span class="text-[11px] tracking-wider uppercase text-muted">Integrations</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <span class="font-mono text-base font-bold text-primary">{platformCount}</span>
      <span class="text-[11px] tracking-wider uppercase text-muted">Platforms</span>
    </div>
    <div class="flex flex-col gap-0.5">
      <span class="font-mono text-base font-bold text-primary">{hubCount}</span>
      <span class="text-[11px] tracking-wider uppercase text-muted">Hubs</span>
    </div>
  </div>
</a>
