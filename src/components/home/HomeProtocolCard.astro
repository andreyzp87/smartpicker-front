---
import { formatProtocolLabel, getProtocolStyle, joinClasses } from "../../lib/ui";

interface Props {
  href: string;
  slug: string | null;
  description: string;
  deviceCount: string;
}

const { href, slug, description, deviceCount } = Astro.props;
const style = getProtocolStyle(slug);
---

<a
  href={href}
  class="card-hover relative overflow-hidden rounded-2xl border border-theme bg-surface p-6 px-5 text-primary"
>
  <div class={joinClasses("absolute inset-x-0 top-0 h-1", style.badge)}></div>
  <div
    class={joinClasses(
      "mb-3.5 flex h-10 w-10 items-center justify-center rounded-[10px] text-sm font-bold",
      style.badge,
      style.text,
    )}
  >
    {style.shortLabel}
  </div>
  <div class="mb-1 text-base font-semibold">{formatProtocolLabel(slug)}</div>
  <div class="font-mono text-[13px] text-muted">{deviceCount} devices</div>
  <p class="mt-3 text-[13px] leading-relaxed text-secondary">{description}</p>
</a>
