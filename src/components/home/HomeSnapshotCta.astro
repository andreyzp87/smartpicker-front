---
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
  generatedLabel: string;
  recentDevicesLabel: string;
}

const { generatedLabel, recentDevicesLabel } = Astro.props;
---

<section class="mx-auto mt-20 max-w-[1200px] px-6">
  <div class="relative flex items-center justify-between gap-8 overflow-hidden rounded-2xl border border-theme bg-cta-gradient p-12 max-md:flex-col max-md:p-8 max-md:text-center">
    <div class="pointer-events-none absolute -top-[100px] -right-[100px] h-[400px] w-[400px] bg-[radial-gradient(circle,var(--sp-blue-glow)_0%,transparent_70%)]">
    </div>
    <div class="relative">
      <h3 class="mb-2 text-2xl font-bold tracking-tight">
        Research with more confidence
      </h3>
      <p class="max-w-[540px] text-[15px] leading-relaxed text-secondary max-md:max-w-none">
        SmartPicker brings devices, integrations, platforms, and hubs into one
        place so it is easier to understand what fits your setup before you
        buy. The catalog was last refreshed {generatedLabel}, and recent
        updates include {recentDevicesLabel}.
      </p>
    </div>
    <div class="relative flex shrink-0 flex-wrap gap-3 max-md:justify-center">
      <ButtonLink href="/about">Learn more</ButtonLink>
      <ButtonLink href="/devices" variant="secondary">Browse catalog</ButtonLink>
    </div>
  </div>
</section>
