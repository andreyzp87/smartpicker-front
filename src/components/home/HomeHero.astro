---
import HomeSearch from "./HomeSearch";

interface StatItem {
  value: string;
  label: string;
}

interface Props {
  indexedDevices: string;
  searchChips: string[];
  stats: StatItem[];
}

const { indexedDevices, searchChips, stats } = Astro.props;
---

<section
  class="relative overflow-hidden px-6 py-20 pb-14 text-center max-md:py-12 max-md:pb-10"
>
  <div
    class="pointer-events-none absolute -top-[200px] left-1/2 h-[600px] w-[800px] -translate-x-1/2 bg-[radial-gradient(ellipse,var(--sp-blue-glow)_0%,transparent_70%)]"
  >
  </div>

  <div class="mx-auto max-w-[1200px]">
    <div
      class="animate-fade-in-up border-blue bg-blue-subtle text-blue mb-6 inline-flex items-center gap-2 rounded-full border px-3.5 py-1.5 text-[13px] font-medium"
    >
      <span
        class="animate-pulse-dot h-1.5 w-1.5 rounded-full bg-[var(--sp-green)]"
      ></span>
      {indexedDevices} devices in the catalog
    </div>

    <h1
      class="animate-fade-in-up mb-4 text-[clamp(36px,5vw,56px)] leading-[1.1] font-bold tracking-[-0.035em]"
      style="animation-delay:0.1s"
    >
      Find smart home devices
      <br />
      that <span class="text-gradient">actually work together</span>
    </h1>

    <p
      class="animate-fade-in-up text-secondary mx-auto mb-9 max-w-[620px] text-[17px] leading-relaxed"
      style="animation-delay:0.2s"
    >
      Search devices, integrations, platforms, manufacturers, and hubs to
      check compatibility, local control, and setup requirements in one place.
    </p>

    <div class="animate-fade-in-up" style="animation-delay:0.3s">
      <HomeSearch
        client:load
        searchChips={searchChips}
        searchEndpoint="/search.json"
        catalogHref="/devices"
        searchEntityTypes={["device", "integration", "platform", "hub", "manufacturer"]}
      />
    </div>

    <div
      class="animate-fade-in-up mx-auto mt-12 flex max-w-[1200px] flex-wrap justify-center gap-6 px-6 max-md:gap-4"
      style="animation-delay:0.4s"
    >
      {
        stats.map((stat, index) => (
          <>
            <div class="min-w-[120px] text-center max-sm:min-w-[calc(50%-0.5rem)]">
              <div class="text-primary font-mono text-[28px] font-bold tracking-tight">
                {stat.value}
              </div>
              <div class="text-muted mt-0.5 text-[13px]">{stat.label}</div>
            </div>
            {index < stats.length - 1 && (
              <div class="h-12 w-px self-center bg-[var(--sp-border)] max-md:hidden" />
            )}
          </>
        ))
      }
    </div>
  </div>
</section>
