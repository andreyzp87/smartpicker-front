---
interface StatItem {
  value: string;
  label: string;
}

interface Props {
  indexedDevices: string;
  searchChips: string[];
  stats: StatItem[];
}

const { indexedDevices, searchChips, stats } = Astro.props;
---

<section class="relative overflow-hidden px-6 py-20 pb-14 text-center max-md:py-12 max-md:pb-10">
  <div class="pointer-events-none absolute -top-[200px] left-1/2 h-[600px] w-[800px] -translate-x-1/2 bg-[radial-gradient(ellipse,var(--sp-blue-glow)_0%,transparent_70%)]">
  </div>

  <div class="mx-auto max-w-[1200px]">
    <div class="animate-fade-in-up mb-6 inline-flex items-center gap-2 rounded-full border border-blue bg-blue-subtle px-3.5 py-1.5 text-[13px] font-medium text-blue">
      <span class="h-1.5 w-1.5 animate-pulse-dot rounded-full bg-[var(--sp-green)]"></span>
      {indexedDevices} devices indexed
    </div>

    <h1
      class="animate-fade-in-up mb-4 text-[clamp(36px,5vw,56px)] font-bold leading-[1.1] tracking-[-0.035em]"
      style="animation-delay:0.1s"
    >
      Find smart home devices
      <br />
      that <span class="text-gradient">actually work together</span>
    </h1>

    <p
      class="animate-fade-in-up mx-auto mb-9 max-w-[620px] text-[17px] leading-relaxed text-secondary"
      style="animation-delay:0.2s"
    >
      Compatibility data from exported SmartPicker snapshots, organized around
      protocols, hub support, and the device makers showing up in the current
      catalog.
    </p>

    <form
      action="/devices"
      method="get"
      class="animate-fade-in-up mx-auto max-w-[620px]"
      style="animation-delay:0.3s"
    >
      <div class="shadow-card focus-within:shadow-search relative flex items-center rounded-[14px] border border-theme-hover bg-input p-1 transition-all focus-within:border-[rgba(37,99,235,0.4)] max-md:flex-col max-md:items-stretch max-md:gap-1.5 max-md:p-2">
        <svg
          class="pointer-events-none absolute left-[18px] top-1/2 -translate-y-1/2 text-muted max-md:top-[22px] max-md:translate-y-0"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          type="search"
          name="q"
          placeholder="Search devices, manufacturers, models..."
          aria-label="Search devices, manufacturers, and models"
          autocomplete="off"
          class="flex-1 border-none bg-transparent py-3.5 pr-4 pl-12 text-base font-[var(--font-sans)] text-primary outline-none placeholder:text-muted max-md:w-full"
        />
        <button
          type="submit"
          class="shadow-blue rounded-[10px] bg-blue-gradient px-6 py-2.5 text-[15px] font-semibold whitespace-nowrap text-white transition-all hover:brightness-110 hover:shadow-blue-lg max-md:w-full"
        >
          Search
        </button>
      </div>
    </form>

    <div class="mt-4 flex flex-wrap justify-center gap-2">
      {
        searchChips.map((chip) => (
          <a
            href={`/devices?q=${encodeURIComponent(chip)}`}
            class="rounded-full border border-theme bg-badge px-3 py-1 text-[13px] text-muted transition-all hover:border-theme-hover hover:bg-hover hover:text-secondary"
          >
            {chip}
          </a>
        ))
      }
    </div>

    <div
      class="animate-fade-in-up mx-auto mt-12 flex max-w-[1200px] flex-wrap justify-center gap-6 px-6 max-md:gap-4"
      style="animation-delay:0.4s"
    >
      {
        stats.map((stat, index) => (
          <>
            <div class="min-w-[120px] text-center max-sm:min-w-[calc(50%-0.5rem)]">
              <div class="font-mono text-[28px] font-bold tracking-tight text-primary">
                {stat.value}
              </div>
              <div class="mt-0.5 text-[13px] text-muted">{stat.label}</div>
            </div>
            {
              index < stats.length - 1 && (
                <div class="h-12 w-px self-center bg-[var(--sp-border)] max-md:hidden"></div>
              )
            }
          </>
        ))
      }
    </div>
  </div>
</section>
