---
import { sentenceCase } from "../../lib/ui";

interface Props {
  href: string;
  name: string;
  kind: string;
  compatibleDeviceCount: string;
  integrationCount: number;
}

const { href, name, kind, compatibleDeviceCount, integrationCount } =
  Astro.props;
---

<a
  href={href}
  class="card-hover rounded-2xl border border-theme bg-surface p-5 text-primary"
>
  <div class="mb-3 flex h-11 w-11 items-center justify-center rounded-[10px] bg-elevated text-sm font-semibold text-muted">
    PF
  </div>
  <div class="text-base font-semibold">{name}</div>
  <div class="mt-1 text-[13px] text-muted">
    {sentenceCase(kind.replace(/_/g, " "))}
  </div>
  <div class="mt-4 flex flex-wrap gap-2 text-[11px] text-muted">
    <span class="rounded-md border border-theme bg-badge px-2 py-1">
      {integrationCount} integration{integrationCount === 1 ? "" : "s"}
    </span>
    <span class="rounded-md border border-theme bg-badge px-2 py-1">
      {compatibleDeviceCount} devices
    </span>
  </div>
</a>
